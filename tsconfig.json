{
	"extends": "astro/tsconfigs/strict",
	"compilerOptions": {
		"types": ["node"],
		"baseUrl": ".",
		"paths": {
			"@/*": ["src/*"],
			"@components/*": ["src/components/*"],
			"@layouts/*": ["src/layouts/*"],
			"@utils/*": ["src/utils/*"],
			"@styles/*": ["src/styles/*"]
		}
	},
	"include": ["src", ".astro/types.d.ts", "emdash-env.d.ts"]
}
