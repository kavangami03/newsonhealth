---
import { getEmDashEntry, getSeoMeta, decodeSlug, getSiteSettings } from "emdash";
import { PortableText } from "emdash/ui";
import Base from "../layouts/Base.astro";
import { resolveStarterSiteIdentity } from "../utils/site-identity";
import AnimatedReveal from "../components/AnimatedReveal";

const slug = decodeSlug(Astro.params.slug);

if (!slug) {
	return Astro.redirect("/404");
}

const { entry: page, cacheHint } = await getEmDashEntry("pages", slug);

if (!page) {
	return Astro.redirect("/404");
}

if (Astro.cache?.enabled) Astro.cache.set(cacheHint);
const { siteTitle } = resolveStarterSiteIdentity(await getSiteSettings());

const seo = getSeoMeta(page, {
	siteTitle,
	siteUrl: Astro.url.origin,
	path: `/${slug}`,
});
---

<Base
	title={seo.title}
	pageTitle={seo.ogTitle}
	description={seo.description}
	canonical={seo.canonical}
	content={{ collection: "pages", id: page.data.id, slug }}
>
	<!-- ═══════════════════════════════════════
	     STATIC PAGE HERO
	     ═══════════════════════════════════════ -->
	<header class="relative bg-gradient-to-br from-peach via-bg-soft-pink to-peachy-pink pt-24 sm:pt-28 md:pt-32 pb-14 sm:pb-20 lg:pb-24 border-b border-black/5 overflow-hidden">
		<div class="absolute top-0 left-0 w-full h-full overflow-hidden pointer-events-none">
			<div class="absolute top-[10%] right-[10%] w-[400px] h-[400px] bg-white/40 rounded-full blur-[100px] animate-blob"></div>
		</div>
		<div class="container mx-auto px-4 sm:px-6 max-w-4xl text-center relative z-10">
			<nav class="flex items-center justify-center gap-2 text-[12px] font-semibold mb-5 sm:mb-6 md:mb-8" aria-label="Breadcrumb">
				<a href="/" class="text-text-grey hover:text-newson-pink transition-colors">Home</a>
				<span class="text-lines opacity-50">/</span>
				<span class="text-newson-pink">{page.data.title}</span>
			</nav>
			<AnimatedReveal client:visible duration={1.2}>
				<h1 class="text-fluid-6xl tracking-tight text-gradient drop-shadow-sm pb-4" {...page.edit.title}>
					{page.data.title}
				</h1>
			</AnimatedReveal>
		</div>
	</header>

	<!-- ═══════════════════════════════════════
	     STATIC PAGE BODY
	     ═══════════════════════════════════════ -->
	<main class="bg-white section-spacing relative" id="static-page-content">
		<div class="absolute top-[20%] left-[-10%] w-[300px] h-[300px] bg-peachy-pink/20 rounded-full blur-[100px] pointer-events-none"></div>
		<div class="container mx-auto px-4 sm:px-6 max-w-3xl relative z-10">
			<AnimatedReveal client:visible yOffset={40} scale={0.98}>
				<article class="glass-panel p-5 sm:p-6 md:p-12 prose max-w-none text-text-grey text-lg leading-relaxed prose-headings:font-display prose-headings:font-normal prose-headings:text-not-quite-black prose-h2:text-3xl prose-h2:mt-12 prose-h2:mb-6 prose-h3:text-2xl prose-h3:mt-10 prose-h3:mb-4 prose-p:mb-6 prose-a:text-newson-pink prose-a:no-underline hover:prose-a:underline hover:prose-a:text-[#c43a57] prose-strong:text-not-quite-black prose-strong:font-semibold prose-blockquote:border-l-4 prose-blockquote:border-newson-pink prose-blockquote:bg-peach/30 prose-blockquote:px-8 prose-blockquote:py-6 prose-blockquote:rounded-r-2xl prose-blockquote:not-italic prose-blockquote:text-not-quite-black prose-ul:list-disc prose-ul:pl-6 prose-ul:mb-6 prose-li:mb-2 prose-img:rounded-3xl prose-img:shadow-premium prose-img:my-10 hover:prose-img:scale-[1.02] hover:prose-img:shadow-premium-hover prose-img:transition-all prose-img:duration-500 prose-img:ease-bounce">
					<PortableText value={page.data.content} />
				</article>
			</AnimatedReveal>
		</div>
	</main>
</Base>
