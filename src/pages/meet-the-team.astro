---
import Base from "../layouts/Base.astro";
import { getSiteSettings, getEmDashCollection } from "emdash";
import { resolveStarterSiteIdentity } from "../utils/site-identity";
import { generateBreadcrumbSchema } from "../utils/schema";
import { getBrand, getPageIntro, splitTitleHighlight, imageUrl } from "../utils/cms";
import AnimatedReveal from "../components/AnimatedReveal";

const { siteTitle } = resolveStarterSiteIdentity(await getSiteSettings());
const brand = await getBrand();
const intro = await getPageIntro("meet-the-team", {
	title: "The minds behind <span>world-class care</span>",
	subtitle: "Our Team",
	description: "Newson Clinic is home to the UK's leading menopause and perimenopause clinicians. All our specialists are highly qualified GPs with advanced hormone certification.",
	breadcrumb_label: "Our Team",
	button_text: "Book Consultation",
	button_url: "https://portal.newsonhealth.co.uk/patient-portal/booking-request",
});
const { before: titleBefore, highlight: titleHighlight, after: titleAfter } = splitTitleHighlight(intro.title ?? "");

const { entries: emdashClinicians } = await getEmDashCollection("clinicians").catch(() => ({ entries: [] }));

const clinicians = emdashClinicians && emdashClinicians.length > 0
	? emdashClinicians.map(entry => {
			const data = entry.data as any;
			return {
				name: data.name as string,
				role: data.role as string,
				credentials: data.credentials as string,
				bio: data.bio as string,
				initials: data.initials as string,
				featured: data.featured as boolean,
				image: imageUrl(data.image),
				edit: entry.edit
			};
	  })
	: [
		{
			name: "Dr Louise Newson",
			role: "Founder & GP Menopause Specialist",
			credentials: "BSc(Hons) MBChB(Hons) MRCP FRCGP",
			bio: "Dr Louise Newson is a leading GP and Menopause Specialist who is passionate about improving education and treatment of the perimenopause and menopause. She founded Newson Clinic to provide dedicated support to women globally.",
			initials: "LN",
			featured: true
		},
		{
			name: "Dr Rebecca Lewis",
			role: "Clinical Director",
			credentials: "MBChB MRCGP DFFP",
			bio: "Dr Rebecca Lewis has been a GP for over 20 years. She has a deep interest in women's hormonal health, specializing in perimenopause and menopause, and works closely with patients to deliver evidence-based care.",
			initials: "RL",
			featured: false
		},
		{
			name: "Dr Sarah Ball",
			role: "Menopause Specialist",
			credentials: "MBChB MRCGP DFFP",
			bio: "Highly experienced in supporting women through hormonal changes. She believes in personalized, patient-centered care and ensuring women have the information they need to make empowered choices.",
			initials: "SB",
			featured: false
		},
		{
			name: "Dr Sarah Glynne",
			role: "Menopause Specialist",
			credentials: "BA(Hons) MBBS MRCP MRCGP",
			bio: "Focusing on advanced women's health, Dr Glynne combines clinical excellence with dedicated empathy to support perimenopause, menopause, and complex hormonal conditions.",
			initials: "SG",
			featured: false
		},
		{
			name: "Dr Clair Crockett",
			role: "GP Specialist",
			credentials: "BSc MBChB MRCGP DRCOG",
			bio: "Dr Crockett brings years of primary care experience, bringing a holistic approach to symptom management and long-term metabolic health during the menopausal transition.",
			initials: "CC",
			featured: false
		}
	];

const breadcrumbSchema = generateBreadcrumbSchema([
	{ name: "Home", url: Astro.url.origin },
	{ name: "Our Team", url: Astro.url.href },
]);

const doctorSchemas = clinicians.map(doc => ({
	"@context": "https://schema.org",
	"@type": "Physician",
	"name": doc.name,
	"jobTitle": doc.role,
	"description": doc.bio,
	"medicalSpecialty": "Menopause Specialist"
}));

const schemas = [breadcrumbSchema, ...doctorSchemas];
---

<Base
	title={`Meet the Team — ${siteTitle}`}
	description="Meet our highly qualified team of GP Menopause Specialists and clinicians dedicated to women's hormonal health."
	schema={schemas}
>
	<!-- ═══════════════════════════════════════
	     TEAM HERO (PREMIUM REDESIGN)
	     ═══════════════════════════════════════ -->
	<header class="relative bg-white pt-24 sm:pt-28 md:pt-32 pb-14 sm:pb-20 lg:pb-24 border-b border-black/5 overflow-hidden">
		<!-- Ultra-premium soft bloom gradients -->
		<div class="absolute inset-0 z-0 pointer-events-none overflow-hidden flex justify-center items-center">
			<div class="w-[800px] h-[800px] bg-gradient-to-tr from-[#fdf5f1] to-[#f7d3d9]/40 rounded-full blur-[120px] opacity-80 mix-blend-multiply absolute top-[-20%] right-[-10%]"></div>
			<div class="w-[600px] h-[600px] bg-[#ea526f]/5 rounded-full blur-[100px] absolute bottom-[-10%] left-[-5%]"></div>
		</div>

		<div class="container mx-auto px-4 sm:px-6 max-w-5xl text-center relative z-10 mt-6 sm:mt-8 md:mt-10">
			<nav class="flex items-center justify-center gap-3 text-[12px] font-bold tracking-widest uppercase mb-6 sm:mb-8 md:mb-10" aria-label="Breadcrumb">
				<a href="/" class="text-text-grey hover:text-[#ea526f] transition-colors">Home</a>
				<span class="text-black/20">/</span>
				<span class="text-[#ea526f]" {...(intro.edit?.breadcrumb_label ?? {})}>{intro.breadcrumb_label}</span>
			</nav>
			<AnimatedReveal client:visible duration={1.2} yOffset={30}>
				<h1 class="font-display text-[2.5rem] sm:text-[3.5rem] md:text-[5rem] lg:text-[5.5rem] text-not-quite-black mb-5 sm:mb-6 md:mb-8 leading-[1.05] tracking-tight" {...(intro.edit?.title ?? {})}>
					{titleHighlight ? (
						<>
							{titleBefore}<br/>
							<span class="text-[#ea526f] italic font-light relative">
								{titleHighlight}
								<svg class="absolute w-full h-4 -bottom-2 left-0 text-[#ea526f]/20" viewBox="0 0 100 10" preserveAspectRatio="none"><path d="M0 5Q50 10 100 5" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"/></svg>
							</span>
							{titleAfter}
						</>
					) : (
						intro.title
					)}
				</h1>
				<p class="text-[1rem] sm:text-[1.15rem] md:text-[1.2rem] lg:text-[1.35rem] text-[#666] max-w-3xl mx-auto leading-relaxed font-medium" {...(intro.edit?.description ?? {})}>
					{intro.description}
				</p>
			</AnimatedReveal>
		</div>
	</header>

	<!-- ═══════════════════════════════════════
	     FEATURED FOUNDER SECTION
	     ═══════════════════════════════════════ -->
	<section class="relative bg-[#fcfcfc] py-12 sm:py-16 md:py-24 lg:py-32 overflow-hidden" id="founder-section">
		<div class="container mx-auto px-4 sm:px-6 max-w-[1400px] relative z-10">
			{clinicians.filter(c => c.featured).map(doctor => (
				<div class="grid grid-cols-1 lg:grid-cols-[1fr_1.5fr] gap-8 sm:gap-12 md:gap-16 lg:gap-24 items-center">
					
					<!-- Stunning Image Composition (uses the clinician's own image from the CMS, with a graceful fallback) -->
					<AnimatedReveal client:visible duration={1.5} yOffset={30} className="relative w-full max-w-lg mx-auto lg:mx-0">
						<div class="relative rounded-[3rem] overflow-hidden shadow-[0_20px_60px_rgba(0,0,0,0.08)] border-[4px] sm:border-[6px] md:border-[8px] border-white aspect-[4/5] bg-gray-100 group">
							<img src={(doctor as any).image || "https://images.unsplash.com/photo-1559839734-2b71ea197ec2?auto=format&fit=crop&w=800&q=80"} alt={doctor.name} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-[2s] ease-out" />
							<div class="absolute inset-0 bg-gradient-to-t from-[#ea526f]/20 to-transparent opacity-60"></div>
						</div>
						
						<!-- Floating Glass Bio Card -->
						<div class="absolute -bottom-10 -right-6 md:-right-12 z-20 bg-white/90 backdrop-blur-xl rounded-[2rem] p-8 shadow-[0_30px_60px_rgba(0,0,0,0.12)] border border-white/60 animate-float w-[300px]">
							<div class="w-14 h-14 rounded-full bg-[#ea526f] flex items-center justify-center text-white text-xl font-display shadow-lg mb-4">
								{doctor.initials}
							</div>
							<p class="text-[13px] text-not-quite-black font-semibold leading-relaxed">
								Passionate about improving education and treatment of perimenopause globally.
							</p>
						</div>
					</AnimatedReveal>

					<!-- Content Side -->
					<AnimatedReveal client:visible duration={1.5} delay={0.2} yOffset={30}>
						<div class="flex flex-col text-center lg:text-left pt-12 lg:pt-0">
							<div class="inline-flex items-center gap-3 px-4 py-2 rounded-full bg-white shadow-sm border border-black/5 mb-5 sm:mb-6 md:mb-8 self-center lg:self-start">
								<span class="w-2 h-2 rounded-full bg-[#ea526f] animate-pulse"></span>
								<span class="text-[#ea526f] text-[12px] font-bold tracking-widest uppercase">{doctor.role}</span>
							</div>

							<h2 class="font-display text-[2.25rem] sm:text-[2.75rem] md:text-[3rem] lg:text-[4.5rem] text-not-quite-black mb-4 leading-none tracking-tight">{doctor.name}</h2>
							<span class="text-[12px] sm:text-[13px] md:text-[14px] font-bold text-text-grey tracking-widest uppercase mb-6 sm:mb-8 md:mb-10 inline-block">{doctor.credentials}</span>

							<div class="relative pl-5 sm:pl-8 mb-6 sm:mb-12 border-l-[3px] border-[#ea526f]">
								<p class="text-[0.95rem] sm:text-[1.05rem] md:text-[1.2rem] lg:text-[1.35rem] text-[#555] leading-relaxed font-medium">
									{doctor.bio}
								</p>
							</div>

							<a href="https://www.drlouisenewson.co.uk" target="_blank" class="px-6 py-3 sm:px-7 sm:py-3.5 md:px-8 md:py-4 bg-[#ea526f] text-white text-[13px] font-bold uppercase tracking-widest rounded-full shadow-[0_10px_30px_rgba(233,81,111,0.3)] hover:shadow-[0_15px_40px_rgba(233,81,111,0.4)] hover:-translate-y-1 transition-all duration-500 ease-out flex items-center gap-3 group self-center lg:self-start">
								Dr Louise's Website
								<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-1.5 transition-transform duration-300"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
							</a>
						</div>
					</AnimatedReveal>
				</div>
			))}
		</div>
	</section>

	<!-- ═══════════════════════════════════════
	     SPECIALISTS GRID (CIRCULAR LAYOUT)
	     ═══════════════════════════════════════ -->
	<main class="relative bg-[#fdf5f1] py-12 sm:py-16 md:py-24 lg:py-32 overflow-hidden" id="specialists-section">
		<div class="container mx-auto px-4 sm:px-6 max-w-[1400px] relative z-10">
			<AnimatedReveal client:visible yOffset={30}>
				<div class="text-center mb-10 sm:mb-14 md:mb-20">
					<h2 class="font-display text-[2.25rem] sm:text-[2.75rem] md:text-[3rem] lg:text-[4.5rem] text-[#ea526f] mb-4 sm:mb-5 md:mb-6 font-normal tracking-tight">Our Clinical Specialists</h2>
					<p class="text-[#666] text-[0.95rem] sm:text-[1.05rem] md:text-[1.2rem] max-w-3xl mx-auto font-medium leading-relaxed">
						Dedicated experts working collaboratively to provide the highest standard of individualized hormonal care.
					</p>
				</div>
			</AnimatedReveal>

			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-2 gap-5 sm:gap-6 md:gap-8 lg:gap-12">
				{clinicians.filter(c => !c.featured).map((doctor, index) => (
					<AnimatedReveal client:visible delay={index * 0.1} yOffset={40} className="h-full">
						<article class="group bg-white rounded-[2.5rem] p-5 sm:p-6 md:p-8 lg:p-10 shadow-[0_10px_30px_rgba(0,0,0,0.04)] border border-black/5 flex flex-col sm:flex-row gap-5 sm:gap-6 md:gap-8 items-center sm:items-start hover:shadow-[0_20px_50px_rgba(233,81,111,0.12)] hover:-translate-y-2 transition-all duration-500 ease-out-expo h-full" id={`doctor-${doctor.name.toLowerCase().replace(/\s+/g, "-")}`}>
							
							<!-- Stunning Circular Portrait -->
							<div class="shrink-0">
								<div class="w-32 h-32 rounded-full bg-gradient-to-br from-[#ea526f] to-[#f7d3d9] flex items-center justify-center shadow-lg border-[6px] border-white/80 relative overflow-hidden group-hover:scale-110 group-hover:rotate-6 transition-all duration-700">
									<div class="absolute inset-0 flex items-center justify-center">
										<span class="font-display text-4xl text-white drop-shadow-md z-10">{doctor.initials}</span>
									</div>
									<div class="absolute inset-0 bg-black/5 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
								</div>
							</div>

							<div class="flex flex-col text-center sm:text-left h-full">
								<span class="text-[12px] font-bold text-[#ea526f] uppercase tracking-[0.2em] mb-2">{doctor.role}</span>
								<h3 class="text-[1.5rem] sm:text-[1.75rem] md:text-[2rem] font-display text-not-quite-black mb-2 group-hover:text-[#ea526f] transition-colors duration-300 leading-tight tracking-tight">{doctor.name}</h3>
								<span class="text-[13px] text-text-grey font-bold tracking-widest uppercase mb-6 block border-b border-black/5 pb-4">{doctor.credentials}</span>
								
								<p class="text-[1.05rem] text-[#555] leading-relaxed mt-auto font-medium">
									{doctor.bio}
								</p>
							</div>

						</article>
					</AnimatedReveal>
				))}
			</div>
		</div>
	</main>

	<!-- ═══════════════════════════════════════
	     CTA SECTION (PREMIUM)
	     ═══════════════════════════════════════ -->
	<section class="bg-white py-12 sm:py-16 md:py-24 lg:py-32 border-t border-black/5 relative overflow-hidden" id="team-cta-section">
		<!-- Huge soft glow -->
		<div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-[#ea526f]/5 rounded-full blur-[120px] pointer-events-none"></div>

		<div class="container mx-auto px-4 sm:px-6 max-w-4xl text-center relative z-10">
			<AnimatedReveal client:visible>
				<div class="w-20 h-20 rounded-full bg-[#fdf5f1] text-[#ea526f] flex items-center justify-center mx-auto mb-6 sm:mb-8 md:mb-10 shadow-sm border border-black/5">
					<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/></svg>
				</div>
				<h2 class="font-display text-[2.25rem] sm:text-[2.75rem] md:text-[3rem] lg:text-[4rem] mb-4 sm:mb-5 md:mb-6 text-not-quite-black tracking-tight leading-none">Ready to start your journey?</h2>
				<p class="text-[0.95rem] sm:text-[1.05rem] md:text-[1.2rem] text-[#666] leading-relaxed mb-6 sm:mb-10 md:mb-12 font-medium max-w-2xl mx-auto">
					Consult with one of our GP Menopause Specialists via video or in-person at our clinic locations. Take control of your hormonal wellness today.
				</p>
				<div class="flex justify-center">
					<a href={intro.button_url ?? brand.booking_url} target="_blank" class="px-7 py-3.5 sm:px-9 sm:py-4 md:px-10 md:py-5 bg-[#ea526f] text-white text-[13px] font-bold uppercase tracking-widest rounded-full shadow-[0_15px_30px_rgba(233,81,111,0.25)] hover:shadow-[0_20px_40px_rgba(233,81,111,0.4)] hover:-translate-y-1 transition-all duration-500 ease-out flex items-center justify-center gap-4 group" {...(intro.edit?.button_text ?? {})}>
						{intro.button_text ?? "Book Consultation"}
						<span class="w-8 h-8 rounded-full bg-white/20 flex items-center justify-center group-hover:bg-white group-hover:text-[#ea526f] transition-colors">
							<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
						</span>
					</a>
				</div>
			</AnimatedReveal>
		</div>
	</section>
</Base>
