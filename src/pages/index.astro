---
import { getEmDashCollection, getSiteSettings } from "emdash";
import Base from "../layouts/Base.astro";
import { resolveStarterSiteIdentity } from "../utils/site-identity";
import { getBrand, getServiceTags, imageUrl } from "../utils/cms";
import AnimatedReveal from "../components/AnimatedReveal";

// Video served as-is from /public to bypass Astro's asset bundling pipeline
// (large MP4s don't survive serverless functions on Vercel).
const heroVideo = "/hero-banner-video.mp4";
import heroPoster from "../images/hero-banner-poster.jpg";
import founderPortrait from "../images/founders/dr-louise-newson-portrait.avif";
import founderClinical from "../images/founders/dr-louise-newson-speaking.avif";
import appointmentsImage from "../images/appointments/dr-louise-consultation.jpg";

const { siteTitle } = resolveStarterSiteIdentity(await getSiteSettings());
const brand = await getBrand();

// 1. Fetch Modular Homepage Sections (Hero, Founders, Services, etc.)
const { entries: emdashSections } = await getEmDashCollection("home_sections").catch(() => ({ entries: [] }));
const sectionsMap = new Map(emdashSections.map((s: any) => [s.slug, s]));

const heroSec = sectionsMap.get("hero") as any;
const foundersSec = sectionsMap.get("founders") as any;
const servicesSec = sectionsMap.get("services") as any;
const clinicsSec = sectionsMap.get("clinics") as any;
const appointmentsSec = sectionsMap.get("appointments") as any;
const adviceSec = sectionsMap.get("advice") as any;
const cliniciansSec = sectionsMap.get("clinicians") as any;

// 2. Fetch Helper Collections for Carousels & Grids
const { entries: emdashServices } = await getEmDashCollection("services", { orderBy: { sort_order: "asc" } }).catch(() => ({ entries: [] }));
const services: any[] = emdashServices.length > 0 ? emdashServices.map((e: any) => ({
	title: e.data.title as string,
	price: e.data.price as string,
	text: e.data.text as string,
	link: e.data.link as string,
	image: imageUrl(e.data.image),
	edit: e.edit,
})) : [
	{ title: "Consultation with a doctor (initial)", price: "£295", text: "To ensure we can offer you the best service, our consultations are designed to personalise our advice for your individual needs.", link: "https://www.newsonhealth.co.uk/services/consultations", image: "https://cdn.prod.website-files.com/683c4dc78bd8a76ef51980b3/685178efacc33ab0b3f4d6e0_Mask%20Group%2016.avif" },
	{ title: "Consultation with a doctor (follow up)", price: "£230", text: "Many patients see major improvements in symptoms within three months, but every journey is different. Follow ups are key to tracking changes.", link: "https://www.newsonhealth.co.uk/services/consultations-follow-up", image: "https://cdn.prod.website-files.com/683c4dc78bd8a76ef51980b3/68c970236950b6ced77cad03_Screenshot%202025-09-16%20151132.png" },
	{ title: "Consultation with a nurse/pharmacist (initial)", price: "£195", text: "To ensure we can offer you the best service, our consultations are designed to personalise our advice for your individual needs.", link: "https://www.newsonhealth.co.uk/services/consultation---new-nurse-pharmacist-led", image: "https://cdn.prod.website-files.com/683c4dc78bd8a76ef51980b3/68b96a1374677aad48c38acf__7R56413.jpg" },
	{ title: "Consultation with a nurse (follow up)", price: "£165", text: "To ensure we can offer you the best service, our consultations are designed to personalise our advice for your individual needs.", link: "https://www.newsonhealth.co.uk/services/consultation---nurse-pharmacist-led-follow-up", image: "https://cdn.prod.website-files.com/683c4dc78bd8a76ef51980b3/68c97079251e57dae5d34907_Screenshot%202025-09-16%20151303.png" },
	{ title: "Testosterone for women", price: "£230", text: "These appointments are designed for women who are already taking HRT and are keen to discuss testosterone as an additional hormone treatment.", link: "https://www.newsonhealth.co.uk/testosterone-for-women", image: "https://cdn.prod.website-files.com/683c4dc78bd8a76ef51980b3/68c970386950b6ced77cbbd1_Screenshot%202025-09-16%20150950.png" },
	{ title: "Consultation - Key worker", price: "£195", text: "We are delighted to offer a discounted first appointment to those working in the emergency services, NHS, teachers, and Armed Forces.", link: "https://www.newsonhealth.co.uk/services/consultation---key-worker", image: "https://cdn.prod.website-files.com/683c4dc78bd8a76ef51980b3/68b8538168ec1098d99fdcee__7R55634.jpg" },
	{ title: "Blood tests", price: "From £95", text: "Newson Clinic offers a range of tests to assess full blood count, kidney function, liver function, lipids, and a full hormone panel.", link: "https://www.newsonhealth.co.uk/services/blood-tests", image: "https://cdn.prod.website-files.com/683c4dc78bd8a76ef51980b3/6862ad958669074422e6c3d4_Blood%20Test%20vials%20and%20paperwork%20on%20a%20desk.avif" },
	{ title: "Advanced thyroid check", price: "£110", text: "Newson Clinic can offer you a comprehensive thyroid function test, including antibodies, for a detailed analysis of thyroid health.", link: "#", image: "https://cdn.prod.website-files.com/683c4dc78bd8a76ef51980b3/6859af0a5eaaade6a051a377_Mask%20Group%20124.avif" },
	{ title: "Enhanced hormone & thyroid", price: "£110", text: "A comprehensive profile including female hormones, thyroid function, and vitamin D levels for a complete wellness overview.", link: "https://www.newsonhealth.co.uk/services/enhanced-hormone-and-thyroid-check-with-added-vit-d", image: "https://cdn.prod.website-files.com/683c4dc78bd8a76ef51980b3/6859af00ab7244250ca31f88_Mask%20Group%20123.avif" },
];

const { entries: emdashClinics } = await getEmDashCollection("clinics", { orderBy: { sort_order: "asc" } }).catch(() => ({ entries: [] }));
const clinics: any[] = emdashClinics.length > 0 ? emdashClinics.map((e: any) => ({
	title: e.data.title as string,
	address1: e.data.address1 as string,
	address2: e.data.address2 as string,
	town: e.data.town as string,
	postcode: e.data.postcode as string,
	image: imageUrl(e.data.image),
	link: e.data.link as string,
	edit: e.edit,
})) : [
	{ title: "London - 4 Harley St", address1: "4 Harley Street", address2: "The Hale Clinic", town: "London", postcode: "W1G 9PB", image: "https://cdn.prod.website-files.com/683c4dc78bd8a76ef51980b3/6a01a7713afef91cc5986c2f_LCC001-scaled.jpg", link: "/clinic/4-harley-street" },
	{ title: "London - 18 Wimpole St", address1: "18 Wimpole Street", address2: "Inuvi Diagnostic Centre", town: "London", postcode: "W1G 8GD", image: "https://cdn.prod.website-files.com/683c4dc78bd8a76ef51980b3/69b7dd8860bde2721121bcde_Image%20(14).jpg", link: "/clinic/london-18-wimpole-street" },
	{ title: "Hale", address1: "185 Ashley Rd", address2: "Bank Medispa", town: "Hale", postcode: "WA15 9SQ", image: "https://cdn.prod.website-files.com/683c4dc78bd8a76ef51980b3/695e6b5bb138761a635560f1_bank-medispa-external-view-crop.jpg", link: "/clinic/hale" },
	{ title: "Video Consultation", address1: "Virtual Appointments", address2: "from your own home", town: "Global", postcode: "", image: "https://cdn.prod.website-files.com/683c4dc78bd8a76ef51980b3/691aefa794777ab5c10e841d_Mask%20Group%20126.png", link: "/clinic/video" },
	{ title: "London - 32 Wimpole St", address1: "32 Wimpole Street", address2: "", town: "London", postcode: "W1G 8GT", image: "https://cdn.prod.website-files.com/683c4dc78bd8a76ef51980b3/691aef85eebacdb88f2c4138_Mask%20Group%20124.png", link: "/clinic/london" },
	{ title: "Stratford-Upon-Avon", address1: "Winton House", address2: "Church Street", town: "Stratford Upon Avon", postcode: "CV37 6HB", image: "https://cdn.prod.website-files.com/683c4dc78bd8a76ef51980b3/691aef69733c2cb3c13cd7c4_Mask%20Group%20123.png", link: "/clinic/stratford-upon-avon" },
];

const { entries: emdashAppointments } = await getEmDashCollection("appointments", { orderBy: { sort_order: "asc" } }).catch(() => ({ entries: [] }));
const appointmentOptions: any[] = emdashAppointments.length > 0 ? emdashAppointments.map((e: any) => ({
	title: e.data.title as string,
	subtitle: e.data.subtitle as string,
	url: e.data.url as string,
	icon: e.data.icon as string,
	edit: e.edit,
})) : [
	{ title: "Video Consultation", subtitle: "From the comfort of your home", url: "/book-video", icon: "video" },
	{ title: "In-person Appointment", subtitle: "Visit us at one of our clinics", url: "/book-in-person", icon: "map-pin" },
];

const { entries: emdashClinicians } = await getEmDashCollection("clinicians").catch(() => ({ entries: [] }));
const clinicians: any[] = emdashClinicians.length > 0 ? emdashClinicians.map((e: any) => ({
	name: e.data.name as string,
	role: e.data.role as string,
	credentials: e.data.credentials as string,
	bio: e.data.bio as string,
	initials: e.data.initials as string,
	image: imageUrl(e.data.image, `https://cdn.prod.website-files.com/683c4dc78bd8a76ef51980b3/69f092f7cf2ebe17032270dc_f03c9575-5eb9-483a-a8e6-e21298924e25.jpg`),
	edit: e.edit,
})) : [
	{ name: "Dr Sally Mok", role: "GP Menopause Specialist", credentials: "MB BS, MRCGP, DRCOG, DFSRH", image: "https://cdn.prod.website-files.com/683c4dc78bd8a76ef51980b3/69f092f7cf2ebe17032270dc_f03c9575-5eb9-483a-a8e6-e21298924e25.jpg", bio: "Highly experienced GP with over 20 years of clinical experience." },
	{ name: "Dr Zaakira Mahomed", role: "GP Menopause Specialist", credentials: "MBChB, MRCGP, DFSRH", image: "https://cdn.prod.website-files.com/683c4dc78bd8a76ef51980b3/69f1d26f13dea6876a15fac2_Zaakira%20Mahomed.png", bio: "Experienced NHS GP with over 11 years of clinical practice." },
	{ name: "Dr Anj Auckloo", role: "GP Menopause Specialist", credentials: "MBChB, MRCGP, PGMEc", image: "https://cdn.prod.website-files.com/683c4dc78bd8a76ef51980b3/69c289bedd1aca8196773760_Screenshot%202026-03-24%20125509.png", bio: "Dedicated passion for women's health and reducing inequalities." },
	{ name: "Dr Victoria Woodhouse", role: "GP Menopause Specialist", credentials: "MBChB, MRCGP, DRCOG", image: "https://cdn.prod.website-files.com/683c4dc78bd8a76ef51980b3/698effdcb3ac55eb10d7515c_Victoria%20Woodhouse.jpg", bio: "Gives her patients the very best evidence-based care and knowledge." },
	{ name: "Dr Sandra Ives", role: "GP Menopause Specialist", credentials: "MBChB, MRCGP, DFSRH", image: "https://cdn.prod.website-files.com/683c4dc78bd8a76ef51980b3/6972202458bcde69473c4c6b_Dr%20Sandra%20Ives.jpg", bio: "GP combining broad primary care expertise with specialist knowledge." },
	{ name: "Dr Yusianmar Borrero", role: "GP Menopause Specialist", credentials: "MBBS, MRCGP", image: "https://cdn.prod.website-files.com/683c4dc78bd8a76ef51980b3/697217046d6035014a4f9367_Screenshot%202026-01-22%20122421.png", bio: "A tireless advocate for women's rights in medicine." },
	{ name: "Dr Helen Winpenny", role: "GP Menopause Specialist", credentials: "MBBS BSc DFFP DRCOG", image: "https://cdn.prod.website-files.com/683c4dc78bd8a76ef51980b3/6968d0bcc48c64aeeaf2b8ce_Screenshot%202026-01-15%20113050.png", bio: "Committed to empowering women to make informed decisions." },
	{ name: "Dr Rebecca Cassin", role: "GP Menopause Specialist", credentials: "MRCGP, MBchB", image: "https://cdn.prod.website-files.com/683c4dc78bd8a76ef51980b3/691df656eafe7d5edf4a8926_Rebecca%20Cassin.jpg", bio: "Passionate about helping women navigate hormonal changes." },
];

const { entries: emdashPosts } = await getEmDashCollection("posts", { orderBy: { published_at: "desc" }, limit: 3 }).catch(() => ({ entries: [] }));
let posts: any[] = emdashPosts.length > 0 ? emdashPosts.map((e: any) => {
	const slug = e.slug || e.id;
	let image = "";
	if (slug.includes("testosterone") || e.data.title?.toLowerCase().includes("testosterone")) {
		image = "https://cdn.prod.website-files.com/683c4dc78bd8a76ef51980b3/68624fd4224281befdb70694_Word%20testosterone%20from%20wooden%20blocks.avif";
	} else if (slug.includes("blood") || e.data.title?.toLowerCase().includes("blood")) {
		image = "https://cdn.prod.website-files.com/683c4dc78bd8a76ef51980b3/6878e2c416536bf36a6e67b2_Blood%20Test%20vials%20and%20paperwork%20on%20a%20desk.jpg";
	} else if (slug.includes("natural-or-synthetic") || e.data.title?.toLowerCase().includes("natural or synthetic")) {
		image = "https://cdn.prod.website-files.com/683c4dc78bd8a76ef51980b3/68624fff94864f61bb4f0022_HRT%20letters%20on%20bluebackground.avif";
	} else {
		image = (e.data.featured_image as string) || "https://cdn.prod.website-files.com/683c4dc78bd8a76ef51980b3/68624fff94864f61bb4f0022_HRT%20letters%20on%20bluebackground.avif";
	}
	return {
		title: e.data.title as string,
		excerpt: e.data.excerpt as string,
		image,
		link: `/posts/${slug}`,
		edit: e.edit,
		slug,
	};
}) : [
	{ title: "Natural or synthetic HRT: understanding the difference", excerpt: "Synthetic HRT and natural hormone replacement therapy for menopause symptoms are not the same - learn the differences", image: "https://cdn.prod.website-files.com/683c4dc78bd8a76ef51980b3/68624fff94864f61bb4f0022_HRT%20letters%20on%20bluebackground.avif", link: "/posts/natural-or-synthetic-hrt-understanding-the-difference", slug: "natural-or-synthetic-hrt-understanding-the-difference" },
	{ title: "What should I know before having a blood test while on HRT?", excerpt: "Newson Clinic's guide to blood tests while on HRT", image: "https://cdn.prod.website-files.com/683c4dc78bd8a76ef51980b3/6878e2c416536bf36a6e67b2_Blood%20Test%20vials%20and%20paperwork%20on%20a%20desk.jpg", link: "/posts/what-should-i-know-before-having-a-blood-test-while-on-hrt", slug: "what-should-i-know-before-having-a-blood-test-while-on-hrt" },
	{ title: "What are the benefits of testosterone for women who take HRT?", excerpt: "Testosterone can be taken alongside oestrogen and/or progesterone to treat perimenopausal and menopausal symptoms", image: "https://cdn.prod.website-files.com/683c4dc78bd8a76ef51980b3/68624fd4224281befdb70694_Word%20testosterone%20from%20wooden%20blocks.avif", link: "/posts/what-are-the-benefits-of-testosterone-for-women-who-take-hrt", slug: "what-are-the-benefits-of-testosterone-for-women-who-take-hrt" },
];

// Sort to ensure the exact requested order
const orderMap: Record<string, number> = {
	"natural-or-synthetic-hrt-understanding-the-difference": 1,
	"what-should-i-know-before-having-a-blood-test-while-on-hrt": 2,
	"what-are-the-benefits-of-testosterone-for-women-who-take-hrt": 3,
};

posts.sort((a, b) => {
	const orderA = orderMap[a.slug] || 99;
	const orderB = orderMap[b.slug] || 99;
	return orderA - orderB;
});


const cmsServiceTags = await getServiceTags();
const serviceTags = cmsServiceTags.length > 0 ? cmsServiceTags : [
	{ name: "Consultation", link: "https://www.newsonhealth.co.uk/consultations" },
	{ name: "Blood Test", link: "https://www.newsonhealth.co.uk/blood-tests" },
	{ name: "DEXA Scan", link: "https://www.newsonhealth.co.uk/dexa-body-scans" },
	{ name: "Coils", link: "https://www.newsonhealth.co.uk/coils" },
	{ name: "Ultrasound", link: "https://www.newsonhealth.co.uk/services/ultrasound-scans" },
	{ name: "Prescriptions", link: "https://www.newsonhealth.co.uk/prescriptions" },
	{ name: "Wellbeing", link: "https://www.newsonhealth.co.uk/health-wellbeing" },
];

const medicalClinicSchema = {
	"@context": "https://schema.org",
	"@type": "MedicalClinic",
	"name": brand.registered_name,
	"alternateName": siteTitle,
	"url": Astro.url.origin,
	"logo": `${Astro.url.origin}/logo.png`,
	"telephone": brand.phone,
	"email": brand.email,
	"address": {
		"@type": "PostalAddress",
		"streetAddress": [brand.address_line1, brand.address_line2].filter(Boolean).join(", "),
		"addressLocality": brand.town,
		"addressRegion": brand.region,
		"postalCode": brand.postcode,
		"addressCountry": brand.country_code,
	},
	"openingHoursSpecification": {
		"@type": "OpeningHoursSpecification",
		"dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
		"opens": brand.hours_open,
		"closes": brand.hours_close,
	},
	"medicalSpecialty": "Gynecologic",
};
---

<Base title={siteTitle} description="Rated Outstanding by CQC, Newson Clinic provides unbiased, evidence-based information to support women's hormonal health and overall wellbeing.">
	<script type="application/ld+json" set:html={JSON.stringify(medicalClinicSchema)}></script>

	<!-- ============ HERO SECTION ============ -->
	<section class="relative min-h-screen w-full bg-[#fcfcfc] overflow-hidden pt-24 sm:pt-28 md:pt-32 pb-14 sm:pb-20 lg:pb-32 lg:pt-40" id="hero-section">
		<!-- Huge abstract background blooms -->
		<div class="absolute top-0 right-0 w-[800px] h-[800px] bg-gradient-to-bl from-[#f7d3d9]/60 to-transparent rounded-full blur-[120px] pointer-events-none -translate-y-1/3 translate-x-1/3"></div>
		<div class="absolute bottom-0 left-0 w-[600px] h-[600px] bg-[#ea526f]/5 rounded-full blur-[120px] pointer-events-none translate-y-1/3 -translate-x-1/3 pointer-events-none"></div>
		<div class="container mx-auto px-4 sm:px-6 max-w-[1520px] relative z-10 h-full">
			<div class="grid grid-cols-1 lg:grid-cols-12 gap-6 sm:gap-10 md:gap-12 lg:gap-8 items-center h-full">
				<!-- Left Column: Typography & Content (7 columns wide) -->
				<div class="lg:col-span-7 flex flex-col pt-6 sm:pt-8 lg:pt-0 z-20">
					<AnimatedReveal client:visible duration={1.2} yOffset={30}>
						<div class="inline-flex items-center gap-4 mb-5 sm:mb-6 md:mb-8 lg:mb-12">
							<div class="w-16 h-[2px] bg-[#ea526f]"></div>
							<span class="text-[#ea526f] text-[12px] font-bold tracking-[0.25em] uppercase" {...heroSec?.edit?.subtitle}>{heroSec?.data?.subtitle ?? "Expert Hormone Care"}</span>
						</div>
					</AnimatedReveal>

					<AnimatedReveal client:visible duration={1.2} delay={0.2} yOffset={40}>
						<h1 class="font-display text-[2.5rem] sm:text-[3.5rem] md:text-[5rem] lg:text-[6.5rem] xl:text-[8rem] leading-[0.9] tracking-[-0.03em] text-not-quite-black mb-6 sm:mb-8 md:mb-10 text-balance" {...heroSec?.edit?.title}>
							{(heroSec?.data?.title ?? "Embrace life again") === "Embrace life again" ? (
								<>
									Embrace <br /> <span class="text-[#ea526f] italic font-light relative inline-block">
										life again
										<!-- Hand-drawn style underline -->
										<svg class="absolute w-[110%] h-[20px] -bottom-2 -left-4 text-[#ea526f]/30" viewBox="0 0 100 20" preserveAspectRatio="none"><path d="M5 15 Q 50 0 95 15" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"></path></svg>
									</span>
								</>
							) : (
								heroSec?.data?.title
							)}
						</h1>
					</AnimatedReveal>

					<AnimatedReveal client:visible duration={1.2} delay={0.4} yOffset={30}>
						<p class="text-[1rem] sm:text-[1.15rem] md:text-[1.25rem] lg:text-[1.5rem] text-[#666] font-medium max-w-[500px] mb-6 sm:mb-10 md:mb-12 leading-[1.6]" {...heroSec?.edit?.description}>
							{heroSec?.data?.description ?? "Rated Outstanding by CQC. We provide unbiased, evidence-based information to support women's hormonal health and overall wellbeing."}
						</p>
					</AnimatedReveal>

					<AnimatedReveal client:visible duration={1.2} delay={0.6} yOffset={20}>
						<div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-3 sm:gap-4">
							<!-- ═══ Primary CTA — split-ticket with arrow notch ═══ -->
							<a
								href={heroSec?.data?.button_url ?? "https://portal.newsonhealth.co.uk/patient-portal/booking-request"}
								target="_blank"
								class="cta-primary group relative inline-flex items-center w-full sm:w-auto h-11 sm:h-[42px] rounded-full bg-[#ea526f] text-white text-[12px] font-bold uppercase tracking-[0.14em] shadow-[0_14px_32px_-10px_rgba(233,81,111,0.55)] hover:shadow-[0_18px_38px_-10px_rgba(233,81,111,0.7)] hover:-translate-y-0.5 transition-all duration-300 ease-out overflow-hidden pl-5 pr-1"
							>
								<!-- Soft animated highlight sweep -->
								<span class="absolute inset-0 -translate-x-full bg-gradient-to-r from-transparent via-white/15 to-transparent group-hover:translate-x-full transition-transform duration-700 ease-out-expo pointer-events-none" aria-hidden="true"></span>
								<span class="relative flex-1 text-center sm:text-left mr-2" {...heroSec?.edit?.button_text}>
									{heroSec?.data?.button_text ?? "Start your journey"}
								</span>
								<!-- Pill end-cap with sliding arrow -->
								<span class="relative h-[34px] sm:h-[32px] aspect-square rounded-full bg-white text-[#ea526f] flex items-center justify-center overflow-hidden shadow-[inset_0_-1px_0_rgba(0,0,0,0.05)]">
									<span class="absolute inset-0 flex items-center justify-center transition-transform duration-400 ease-out-expo group-hover:translate-x-7">
										<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
									</span>
									<span class="absolute inset-0 flex items-center justify-center transition-transform duration-400 ease-out-expo -translate-x-7 group-hover:translate-x-0">
										<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
									</span>
								</span>
							</a>

							<!-- ═══ Secondary CTA — ghost with growing underline ═══ -->
							<a
								href="#founders-section"
								class="cta-secondary group relative inline-flex items-center justify-center w-full sm:w-auto h-11 sm:h-[42px] gap-3 px-5 rounded-full text-not-quite-black text-[12px] font-bold uppercase tracking-[0.14em] border border-black/10 bg-white/40 backdrop-blur-sm hover:border-not-quite-black hover:bg-not-quite-black hover:text-white hover:-translate-y-0.5 transition-all duration-300 ease-out"
							>
								<!-- Avatar dot stack -->
								<span class="relative flex -space-x-1.5">
									<span class="block w-4 h-4 rounded-full bg-[#ea526f] border-[1.5px] border-white"></span>
									<span class="block w-4 h-4 rounded-full bg-[#f7d3d9] border-[1.5px] border-white"></span>
								</span>
								<span class="relative">Meet the founders</span>
