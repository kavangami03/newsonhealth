---
import Base from "../layouts/Base.astro";
import { getSiteSettings, getEmDashCollection } from "emdash";
import { resolveStarterSiteIdentity } from "../utils/site-identity";
import { generateBreadcrumbSchema } from "../utils/schema";
import AnimatedReveal from "../components/AnimatedReveal";
import FaqAccordion from "../components/FaqAccordion";

const { siteTitle } = resolveStarterSiteIdentity(await getSiteSettings());

const { entries: emdashFaqs } = await getEmDashCollection("faqs").catch(() => ({ entries: [] }));

let faqCategories;
if (emdashFaqs && emdashFaqs.length > 0) {
	const groups: Record<string, any> = {};
	emdashFaqs.forEach(entry => {
		const cat = (entry.data.category || "General") as string;
		if (!groups[cat]) {
			groups[cat] = [];
		}
		groups[cat].push({ q: entry.data.question, a: entry.data.answer });
	});
	faqCategories = Object.keys(groups).map(title => ({
		title,
		faqs: groups[title]
	}));
} else {
	faqCategories = [
		{
			title: "Consultations & Appointments",
			faqs: [
				{
					q: "How do I book a consultation at Newson Clinic?",
					a: "You can book an appointment by filling out our online booking request form on our secure Patient Portal, or by calling our patient support team on 01789 595004. We offer both in-person consultations at our clinics and video consultations nationwide.",
				},
				{
					q: "Do you offer online video consultations?",
					a: "Yes, we offer secure video consultations for patients across the UK and internationally. Video consultations are highly popular, highly convenient, and held with the exact same expert GP Menopause Specialists as our in-person visits.",
				},
				{
					q: "Do I need a GP referral to visit Newson Clinic?",
					a: "No, you do not need a GP referral. We welcome self-referrals from all patients seeking specialized menopause support, perimenopause support, or hormone wellness advice.",
				},
			],
		},
		{
			title: "Hormone Replacement Therapy (HRT)",
			faqs: [
				{
					q: "What type of HRT do you prescribe?",
					a: "We prioritize prescribing body-identical (also known as regulated bio-identical) hormones, which are derived from natural plant sources (yam) and are structurally identical to the hormones produced by your own body. These carry significantly lower risks compared to older synthetic hormones.",
				},
				{
					q: "How long does it take for HRT to start working?",
					a: "Many patients start noticing improvements in symptoms like hot flushes and night sweats within 2 to 4 weeks. However, other symptoms such as joint pain, mood shifts, and brain fog can take 3 to 6 months to fully stabilize. We schedule follow-ups at 3 months to monitor progress.",
				},
				{
					q: "Are body-identical hormones safe?",
					a: "Yes, body-identical hormones (specifically transdermal oestrogen and micronised progesterone) have an outstanding safety profile. Unlike older synthetic oral treatments, transdermal oestrogen does not increase the risk of blood clots or stroke, and carries no increased risk of breast cancer when used appropriately.",
				},
			],
		},
		{
			title: "Blood Tests & Diagnostics",
			faqs: [
				{
					q: "Do I need blood tests before my first consultation?",
					a: "Not necessarily. In most cases, perimenopause and menopause are diagnosed based on your symptoms and clinical history rather than blood hormone levels (which can fluctuate wildly from day to day). Your clinician will advise you during your initial consultation if blood tests are necessary.",
				},
				{
					q: "What is a DEXA scan and why is it important?",
					a: "A DEXA scan is a quick, painless scan that measures bone mineral density. Since oestrogen declines during menopause, bone loss can accelerate, increasing the risk of osteoporosis. We offer DEXA scans at our Stratford clinic to assess bone health and screen for osteoporosis risk.",
				},
			],
		},
	];
}

const breadcrumbSchema = generateBreadcrumbSchema([
	{ name: "Home", url: Astro.url.origin },
	{ name: "FAQs", url: Astro.url.href },
]);
---

<Base
	title={`Frequently Asked Questions — ${siteTitle}`}
	description="Find answers to common questions about menopause consults, appointment booking, body identical HRT, prescriptions, and blood tests."
	schema={breadcrumbSchema}
>
	<!-- ═══════════════════════════════════════
	     FAQS HERO
	     ═══════════════════════════════════════ -->
	<header class="relative bg-mesh-gradient pt-20 sm:pt-24 pb-10 sm:pb-14 md:pb-16 border-b border-black/5 overflow-hidden">
		<div class="absolute top-0 left-0 w-full h-full overflow-hidden pointer-events-none">
			<div class="absolute top-[-20%] left-[-10%] w-[500px] h-[500px] bg-newson-pink/10 rounded-full blur-[100px] animate-blob"></div>
			<div class="absolute bottom-[-20%] right-[-10%] w-[400px] h-[400px] bg-complimentary-pink/15 rounded-full blur-[120px] animate-blob animation-delay-2000"></div>
		</div>
		<div class="container mx-auto px-4 sm:px-6 max-w-4xl text-center relative z-10">
			<nav class="flex items-center justify-center gap-2 text-[12px] font-semibold mb-4 sm:mb-5 md:mb-6" aria-label="Breadcrumb">
				<a href="/" class="text-text-grey hover:text-newson-pink transition-colors">Home</a>
				<span class="text-lines opacity-50">/</span>
				<span class="text-newson-pink">FAQs</span>
			</nav>
			<AnimatedReveal client:visible duration={1.2}>
				<h1 class="text-fluid-5xl mb-6 tracking-tight text-gradient drop-shadow-sm">Frequently Asked Questions</h1>
				<p class="text-lg text-text-grey max-w-2xl mx-auto leading-relaxed glass-panel px-6 py-4">
					Have questions about appointments, body-identical HRT, prescriptions, or diagnostics? We've compiled expert answers to help you feel informed and confident.
				</p>
			</AnimatedReveal>
		</div>
	</header>

	<!-- ═══════════════════════════════════════
	     FAQS ACCORDIONS
	     ═══════════════════════════════════════ -->
	<main class="relative bg-buff section-spacing overflow-hidden" id="faq-accordions-section">
		<div class="absolute top-0 right-0 w-[50%] h-[60%] bg-[radial-gradient(circle,var(--color-peach)_0%,transparent_70%)] opacity-50 pointer-events-none mix-blend-multiply"></div>
		
		<div class="container mx-auto px-4 sm:px-6 max-w-3xl relative z-10 glass-panel p-5 sm:p-6 md:p-12">
			<AnimatedReveal client:visible duration={1.2} yOffset={30}>
				<FaqAccordion client:visible categories={faqCategories} />
			</AnimatedReveal>
		</div>
	</main>

	<!-- ═══════════════════════════════════════
	     CTA SECTION
	     ═══════════════════════════════════════ -->
	<section class="bg-white section-spacing border-t border-black/5 relative overflow-hidden" id="faqs-cta-section">
		<div class="absolute top-[-30%] left-[-10%] w-[400px] h-[400px] bg-peachy-pink/20 rounded-full blur-[80px] animate-blob pointer-events-none"></div>
		
		<div class="container mx-auto px-4 sm:px-6 max-w-3xl text-center relative z-10">
			<AnimatedReveal client:visible>
				<h2 class="text-fluid-4xl mb-4 sm:mb-5 md:mb-6 text-gradient drop-shadow-sm">Still have questions?</h2>
				<p class="text-base sm:text-lg text-text-grey leading-relaxed mb-6 sm:mb-8 md:mb-10">
					If you couldn't find the answer you were looking for, please get in touch with our friendly support team or book a consultation.
				</p>
				<div class="flex flex-col sm:flex-row gap-4 sm:gap-6 justify-center">
					<a href="/contact-us" class="px-7 py-3.5 sm:px-9 sm:py-4 md:px-10 md:py-5 bg-not-quite-black text-white text-sm font-semibold uppercase tracking-widest rounded-full shadow-premium hover:shadow-glow hover:-translate-y-2 hover:scale-105 hover:bg-newson-pink transition-all duration-500 ease-bounce" id="faq-cta-contact">
						Contact Support
					</a>
					<a href="https://portal.newsonhealth.co.uk/patient-portal/booking-request" target="_blank" class="glass-panel px-7 py-3.5 sm:px-9 sm:py-4 md:px-10 md:py-5 text-newson-pink text-sm font-semibold uppercase tracking-widest rounded-full hover:-translate-y-2 hover:scale-105 hover:border-newson-pink/40 transition-all duration-500 ease-bounce" id="faq-cta-book">
						Book Consultation
					</a>
				</div>
			</AnimatedReveal>
		</div>
	</section>
</Base>
