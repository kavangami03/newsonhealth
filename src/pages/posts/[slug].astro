---
import { getEmDashEntry, getEntryTerms, getSeoMeta, decodeSlug, getSiteSettings, getEmDashCollection } from "emdash";
import { Image, PortableText, WidgetArea } from "emdash/ui";
import Base from "../../layouts/Base.astro";
import { resolveStarterSiteIdentity } from "../../utils/site-identity";
import { generateBreadcrumbSchema, generateOrganizationSchema, generateMedicalWebPageSchema } from "../../utils/schema";
import AnimatedReveal from "../../components/AnimatedReveal";

const slug = decodeSlug(Astro.params.slug);

if (!slug) {
	return Astro.redirect("/404");
}

const { entry: post, cacheHint } = await getEmDashEntry("posts", slug);

if (!post) {
	return Astro.redirect("/404");
}

if (Astro.cache?.enabled) Astro.cache.set(cacheHint);
const { siteTitle } = resolveStarterSiteIdentity(await getSiteSettings());

// SEO meta from content fields
const seo = getSeoMeta(post, {
	siteTitle,
	siteUrl: Astro.url.origin,
	path: `/posts/${slug}`,
});

// Taxonomy terms for this post
const tags = await getEntryTerms("posts", post.data.id, "tag");
const categories = await getEntryTerms("posts", post.data.id, "category");

// Fetch related articles for the bottom section
const { entries: recentPosts } = await getEmDashCollection("posts", {
	orderBy: { published_at: "desc" },
	limit: 4,
});
const relatedPosts = recentPosts.filter((p) => p.data.id !== post.data.id).slice(0, 3);

// Generate structured data
const breadcrumbSchema = generateBreadcrumbSchema([
	{ name: "Home", url: Astro.url.origin },
	{ name: "Knowledge Library", url: `${Astro.url.origin}/posts` },
	{ name: post.data.title, url: Astro.url.href },
]);

const medicalSchema = generateMedicalWebPageSchema(
	seo.title,
	seo.description || "",
	Astro.url.href,
	post.data.publishedAt?.toISOString(),
	(seo.ogImage as any)?.url || (seo.ogImage as any)
);

const schemas = [breadcrumbSchema, medicalSchema];
---

<Base
	title={seo.title}
	pageTitle={seo.ogTitle}
	description={seo.description}
	canonical={seo.canonical}
	image={seo.ogImage}
	content={{ collection: "posts", id: post.data.id, slug }}
	schema={schemas}
	pageType="article"
>
	<!-- ═══════════════════════════════════════
	     ARTICLE CONTAINER
	     ═══════════════════════════════════════ -->
	<div class="bg-white pt-24 md:pt-32 pb-16">
		<!-- Header / Breadcrumb & Meta -->
		<header class="mb-12 md:mb-16">
			<div class="container mx-auto px-6 max-w-4xl text-center">
				<nav class="flex items-center justify-center gap-2 text-[11px] md:text-xs font-medium mb-8 flex-wrap" aria-label="Breadcrumb">
					<a href="/" class="text-text-grey hover:text-newson-pink transition-colors">Home</a>
					<span class="text-lines opacity-50">/</span>
					<a href="/posts" class="text-text-grey hover:text-newson-pink transition-colors">Knowledge Library</a>
					<span class="text-lines opacity-50 hidden sm:inline">/</span>
					<span class="text-newson-pink hidden sm:inline max-w-[250px] truncate">{post.data.title}</span>
				</nav>

				{categories.length > 0 && (
					<AnimatedReveal client:visible>
						<div class="mb-6">
							<a href={`/category/${categories[0].slug}`} class="inline-block px-4 py-1.5 bg-bg-soft-pink text-newson-pink text-[10px] md:text-xs font-semibold rounded-full uppercase tracking-widest border border-newson-pink/15 hover:bg-newson-pink hover:text-white transition-colors">
								{categories[0].label}
							</a>
						</div>
					</AnimatedReveal>
				)}

				<AnimatedReveal client:visible yOffset={30}>
					<h1 class="text-4xl md:text-5xl lg:text-fluid-5xl font-display text-not-quite-black leading-tight mb-8 max-w-[32ch] mx-auto" {...post.edit.title}>
						{post.data.title}
					</h1>
				</AnimatedReveal>

				<AnimatedReveal client:visible yOffset={20} delay={0.2}>
					<div class="flex flex-col sm:flex-row items-center justify-center gap-6 sm:gap-10 border-y border-black/5 py-4 max-w-[550px] mx-auto">
						<div class="flex items-center gap-3 text-left">
							<div class="w-10 h-10 bg-peachy-pink text-newson-pink flex items-center justify-center rounded-full font-display font-medium text-sm border border-newson-pink/20">LN</div>
							<div class="flex flex-col">
								<span class="text-sm font-semibold text-not-quite-black">Dr Louise Newson</span>
								<span class="text-xs text-text-grey">Founder &amp; Clinician</span>
							</div>
						</div>

						<div class="text-sm text-text-grey">
							{post.data.publishedAt && (
								<time datetime={post.data.publishedAt.toISOString()} class="flex items-center gap-2">
									<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-newson-pink"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
									{post.data.publishedAt.toLocaleDateString("en-GB", {
										year: "numeric",
										month: "long",
										day: "numeric",
									})}
								</time>
							)}
						</div>
					</div>
				</AnimatedReveal>
			</div>
		</header>

		<!-- Large Hero Featured Image -->
		{post.data.featured_image && (
			<section class="container mx-auto px-6 max-w-6xl mb-16 md:mb-24" {...post.edit.featured_image}>
				<AnimatedReveal client:visible>
					<div class="w-full rounded-2xl md:rounded-[2rem] overflow-hidden shadow-premium aspect-[16/9] md:aspect-[21/9] max-h-[500px]">
						<Image image={post.data.featured_image} class="w-full h-full object-cover" />
					</div>
				</AnimatedReveal>
			</section>
		)}

		<!-- Content & Sidebar Layout -->
		<div class="container mx-auto px-6 max-w-6xl mb-24">
			<div class="grid grid-cols-1 lg:grid-cols-[1fr_350px] gap-12 lg:gap-16">
				<!-- Left Column: PortableText Content -->
				<main class="min-w-0" id="article-main-content">
					<AnimatedReveal client:visible yOffset={40}>
						<article class="prose max-w-none text-text-grey text-lg leading-relaxed prose-headings:font-display prose-headings:font-normal prose-headings:text-not-quite-black prose-h2:text-3xl prose-h2:mt-12 prose-h2:mb-6 prose-h3:text-2xl prose-h3:mt-10 prose-h3:mb-4 prose-p:mb-6 prose-a:text-newson-pink prose-a:no-underline hover:prose-a:underline hover:prose-a:text-[#c43a57] prose-strong:text-not-quite-black prose-strong:font-semibold prose-blockquote:border-l-4 prose-blockquote:border-newson-pink prose-blockquote:bg-bg-warm prose-blockquote:px-8 prose-blockquote:py-6 prose-blockquote:rounded-r-2xl prose-blockquote:not-italic prose-blockquote:text-not-quite-black prose-ul:list-disc prose-ul:pl-6 prose-ul:mb-6 prose-li:mb-2 prose-img:rounded-2xl prose-img:shadow-premium prose-img:my-10">
							<PortableText value={post.data.content} />
						</article>
					</AnimatedReveal>

					<!-- Tags section -->
					{tags.length > 0 && (
						<AnimatedReveal client:visible yOffset={20}>
							<footer class="mt-14 pt-8 border-t border-black/5">
								<div class="flex flex-wrap items-center gap-2">
									<span class="text-sm font-semibold text-not-quite-black mr-2">Tags:</span>
									{tags.map((t) => (
										<a href={`/tag/${t.slug}`} class="px-3 py-1 bg-buff text-text-grey text-xs font-medium rounded-full border border-black/5 hover:bg-newson-pink hover:text-white hover:border-newson-pink transition-colors">
											{t.label}
										</a>
									))}
								</div>
							</footer>
						</AnimatedReveal>
					)}
				</main>

				<!-- Right Column: Sticky Sidebar -->
				<aside aria-label="Sidebar" class="relative">
					<div class="sticky top-24 flex flex-col gap-8">
						<!-- Custom Clinician Trust Widget -->
						<AnimatedReveal client:visible yOffset={30}>
							<div class="premium-surface p-8 bg-buff/50 border-l-4 border-l-newson-pink">
								<h3 class="text-lg font-medium text-not-quite-black mb-4 pb-2 border-b border-newson-pink/20">Evidence-Based Medicine</h3>
								<p class="text-sm text-text-grey leading-relaxed mb-4">
									All information on Newson Clinic is written or reviewed by menopause and hormone experts to ensure medical accuracy.
								</p>
								<div class="flex flex-col text-xs">
									<strong class="text-not-quite-black font-semibold">Dr Louise Newson</strong>
									<span class="text-lines">BSc(Hons) MBChB(Hons) MRCP FRCGP</span>
								</div>
							</div>
						</AnimatedReveal>

						<!-- Appointment CTA Widget -->
						<AnimatedReveal client:visible yOffset={30} delay={0.1}>
							<div class="premium-surface p-8 bg-gradient-to-br from-peach to-peachy-pink border border-newson-pink/20 shadow-glow">
								<h3 class="text-lg font-medium text-not-quite-black mb-4 pb-2 border-b border-black/5">Consult a Specialist</h3>
								<p class="text-sm text-text-grey leading-relaxed mb-6">
									Get personalized treatment and support for perimenopause, menopause, or hormonal issues.
								</p>
								<a href="https://portal.newsonhealth.co.uk/patient-portal/booking-request" target="_blank" class="block w-full py-3.5 bg-not-quite-black text-white text-center text-xs font-medium uppercase tracking-wider rounded-full shadow-premium hover:shadow-glow hover:-translate-y-1 hover:bg-newson-pink transition-all duration-400 ease-out-expo mb-4" id="sidebar-cta">
									Book Consultation
								</a>
								<a href="tel:01789595004" class="flex items-center justify-center gap-2 text-sm font-semibold text-newson-pink hover:text-[#c43a57] transition-colors">
									<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
									01789 595004
								</a>
							</div>
						</AnimatedReveal>

						<!-- EmDash Dynamic Sidebar widgets -->
						<AnimatedReveal client:visible yOffset={30} delay={0.2}>
							<div class="premium-surface p-8 bg-white">
								<WidgetArea name="sidebar" />
							</div>
						</AnimatedReveal>
					</div>
				</aside>
			</div>
		</div>

		<!-- Related / Recommended Articles -->
		{relatedPosts.length > 0 && (
			<section class="bg-buff section-spacing border-t border-black/5" id="related-articles-section">
				<div class="container mx-auto px-6 max-w-6xl">
					<AnimatedReveal client:visible>
						<h2 class="text-3xl font-display text-center mb-12">You might also like</h2>
					</AnimatedReveal>
					
					<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
						{relatedPosts.map((rPost, index) => (
							<AnimatedReveal client:visible yOffset={30} delay={index * 0.1}>
								<a href={`/posts/${rPost.id}`} class="premium-surface group bg-white overflow-hidden flex flex-col h-full hover:-translate-y-2 hover:shadow-premium-hover transition-all duration-400 ease-out-expo border border-black/5" id={`related-post-${rPost.id}`}>
									{rPost.data.featured_image && (
										<div class="h-[200px] overflow-hidden">
											<Image image={rPost.data.featured_image} class="w-full h-full object-cover transition-transform duration-700 ease-out-expo group-hover:scale-105" />
										</div>
									)}
									<div class="p-6 flex flex-col gap-3 flex-grow">
										<h3 class="text-lg font-medium text-not-quite-black leading-snug group-hover:text-newson-pink transition-colors line-clamp-2">{rPost.data.title}</h3>
										{rPost.data.publishedAt && (
											<time class="mt-auto text-xs text-lines" datetime={rPost.data.publishedAt.toISOString()}>
												{rPost.data.publishedAt.toLocaleDateString("en-GB", {
													year: "numeric",
													month: "short",
													day: "numeric",
												})}
											</time>
										)}
									</div>
								</a>
							</AnimatedReveal>
						))}
					</div>
				</div>
			</section>
		)}
	</div>
</Base>
