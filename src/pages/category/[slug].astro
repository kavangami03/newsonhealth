---
import { getTerm, getEmDashCollection, decodeSlug, getSiteSettings, getTermsForEntries } from "emdash";
import { Image } from "emdash/ui";
import Base from "../../layouts/Base.astro";
import { resolveStarterSiteIdentity } from "../../utils/site-identity";

const slug = decodeSlug(Astro.params.slug);
const term = slug ? await getTerm("category", slug) : null;

if (!term) {
	return Astro.redirect("/404");
}

const { entries: posts, cacheHint } = await getEmDashCollection("posts", {
	where: { category: term.slug },
	orderBy: { published_at: "desc" },
});
if (Astro.cache?.enabled) Astro.cache.set(cacheHint);

const { siteTitle } = resolveStarterSiteIdentity(await getSiteSettings());

// Batch get both tags and categories for our posts
const postIds = posts.map((p) => p.data.id);
const tagsByEntry = await getTermsForEntries("posts", postIds, "tag");
const categoriesByEntry = await getTermsForEntries("posts", postIds, "category");

const postsWithMeta = posts.map((post) => {
	const tags = tagsByEntry.get(post.data.id) ?? [];
	const categories = categoriesByEntry.get(post.data.id) ?? [];
	return {
		post,
		tags,
		categories,
	};
});
---

<Base
	title={`${term.label} Articles — ${siteTitle}`}
	description={`Explore our evidence-based clinical articles and guides related to ${term.label}.`}
>
	<!-- ═══════════════════════════════════════
	     CATEGORY HERO
	     ═══════════════════════════════════════ -->
	<header class="category-hero">
		<div class="container category-hero__container">
			<nav class="breadcrumb reveal" aria-label="Breadcrumb">
				<a href="/">Home</a>
				<span class="breadcrumb__separator">/</span>
				<a href="/posts">Knowledge Library</a>
				<span class="breadcrumb__separator">/</span>
				<span class="breadcrumb__current">{term.label}</span>
			</nav>
			<span class="category-hero__badge reveal">Category Archive</span>
			<h1 class="category-hero__title reveal">{term.label}</h1>
			<p class="category-hero__subtitle reveal">
				Discover all articles, resources, and evidence-based research filed under <strong>{term.label}</strong>.
			</p>
		</div>
	</header>

	<!-- ═══════════════════════════════════════
	     CATEGORY MAIN LIST
	     ═══════════════════════════════════════ -->
	<main class="category-main section">
		<div class="container">
			<div class="category-layout">
				<!-- Left Column: Posts Grid -->
				<section class="category-content" id="category-articles-section">
					{postsWithMeta.length === 0 ? (
						<div class="no-posts reveal">
							<p>We are currently writing new articles for this category. Please check back soon!</p>
							<a href="/posts" class="btn btn-secondary btn-sm mt-4">
								Browse all articles
							</a>
						</div>
					) : (
						<div class="category-grid">
							{postsWithMeta.map(({ post, tags, categories }) => (
								<article class="library-card reveal" id={`category-post-card-${post.id}`}>
									{post.data.featured_image ? (
										<a href={`/posts/${post.id}`} class="library-card__image-link" aria-label={`Read ${post.data.title}`}>
											<div class="library-card__image-wrapper">
												<Image image={post.data.featured_image} />
											</div>
										</a>
									) : (
										<div class="library-card__image-placeholder">
											<span>Newson Clinic</span>
										</div>
									)}

									<div class="library-card__body">
										<div class="library-card__meta">
											{categories.length > 0 && (
												<span class="library-card__category">{categories[0].label}</span>
											)}
											{post.data.publishedAt && (
												<time class="library-card__date" datetime={post.data.publishedAt.toISOString()}>
													{post.data.publishedAt.toLocaleDateString("en-GB", {
														year: "numeric",
														month: "short",
														day: "numeric",
													})}
												</time>
											)}
										</div>

										<h3 class="library-card__title">
											<a href={`/posts/${post.id}`}>{post.data.title}</a>
										</h3>

										{post.data.excerpt && (
											<p class="library-card__excerpt">{post.data.excerpt}</p>
										)}

										<div class="library-card__footer">
											{tags.length > 0 && (
												<div class="library-card__tags">
													{tags.slice(0, 2).map((t) => (
														<a href={`/tag/${t.slug}`} class="tag-badge">{t.label}</a>
													))}
												</div>
											)}
											<a href={`/posts/${post.id}`} class="library-card__link" aria-label={`Read ${post.data.title}`}>
												Read &rarr;
											</a>
										</div>
									</div>
								</article>
							))}
						</div>
					)}
				</section>

				<!-- Right Column: Sidebar -->
				<aside class="category-sidebar" aria-label="Sidebar">
					<!-- Booking CTA Widget -->
					<div class="sidebar-widget booking-widget reveal">
						<h3 class="widget-title">Consult a Specialist</h3>
						<p class="booking-widget__text">
							Our team of menopause and hormonal health clinicians are here to support you at every stage of your journey.
						</p>
						<a href="https://portal.newsonhealth.co.uk/patient-portal/booking-request" target="_blank" class="btn btn-primary btn-sm w-full" id="category-sidebar-cta">
							Book Appointment
						</a>
						<a href="tel:01789595004" class="booking-widget__phone">
							📞 01789 595004
						</a>
					</div>
				</aside>
			</div>
		</div>
	</main>
</Base>

<style>
	/* ════════════════════════════════════════
	   CATEGORY HERO
	   ════════════════════════════════════════ */
	.category-hero {
		background: linear-gradient(135deg, var(--color-peach) 0%, var(--color-bg-soft-pink) 50%, var(--color-peachy-pink) 100%);
		padding-block: clamp(3rem, 2rem + 3vw, 5rem);
		border-bottom: 1px solid rgba(173, 172, 172, 0.1);
	}

	.category-hero__container {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	/* Breadcrumbs */
	.breadcrumb {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		font-size: var(--text-xs);
		font-weight: 500;
	}

	.breadcrumb a {
		color: var(--color-text-grey);
		transition: color 0.2s ease;
	}

	.breadcrumb a:hover {
		color: var(--color-newson-pink);
	}

	.breadcrumb__separator {
		color: var(--color-lines);
		opacity: 0.5;
	}

	.breadcrumb__current {
		color: var(--color-newson-pink);
	}

	.category-hero__badge {
		align-self: flex-start;
		font-size: 10px;
		font-weight: 600;
		color: var(--color-newson-pink);
		text-transform: uppercase;
		letter-spacing: 0.05em;
		padding: 0.2rem 0.6rem;
		background-color: rgba(233, 81, 111, 0.08);
		border-radius: var(--radius-sm);
		margin-top: 0.5rem;
	}

	.category-hero__title {
		font-size: var(--text-4xl);
		color: var(--color-not-quite-black);
		line-height: 1.1;
	}

	.category-hero__subtitle {
		font-size: var(--text-base);
		color: var(--color-text-grey);
		max-width: 700px;
		line-height: 1.6;
	}

	/* ════════════════════════════════════════
	   LAYOUT
	   ════════════════════════════════════════ */
	.category-main {
		background-color: var(--color-white);
	}

	.category-layout {
		display: grid;
		grid-template-columns: 2.2fr 1fr;
		gap: 4rem;
	}

	@media (max-width: 991px) {
		.category-layout {
			grid-template-columns: 1fr;
			gap: 3rem;
		}
	}

	/* ── Grid ── */
	.category-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 2.5rem;
	}

	@media (max-width: 640px) {
		.category-grid {
			grid-template-columns: 1fr;
			gap: 1.75rem;
		}
	}

	.library-card {
		background-color: var(--color-white);
		border-radius: var(--radius-lg);
		border: 1px solid rgba(173, 172, 172, 0.12);
		box-shadow: var(--shadow-sm);
		overflow: hidden;
		display: flex;
		flex-direction: column;
		transition: transform 0.4s var(--ease-out-expo), box-shadow 0.4s var(--ease-out-expo);
	}

	.library-card:hover {
		transform: translateY(-4px);
		box-shadow: var(--shadow-md);
	}

	.library-card__image-link {
		display: block;
		height: 200px;
		overflow: hidden;
		position: relative;
	}

	.library-card__image-wrapper {
		width: 100%;
		height: 100%;
	}

	.library-card__image-wrapper :global(img) {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.6s var(--ease-out-expo);
	}

	.library-card:hover .library-card__image-wrapper :global(img) {
		transform: scale(1.04);
	}

	.library-card__image-placeholder {
		display: flex;
		align-items: center;
		justify-content: center;
		height: 200px;
		background: linear-gradient(135deg, var(--color-peach), var(--color-peachy-pink));
		color: var(--color-newson-pink);
		font-family: var(--font-display);
		font-size: var(--text-xl);
	}

	.library-card__body {
		padding: 1.5rem;
		display: flex;
		flex-direction: column;
		flex-grow: 1;
		gap: 1rem;
	}

	.library-card__meta {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		font-size: var(--text-xs);
	}

	.library-card__category {
		font-weight: 600;
		color: var(--color-newson-pink);
		text-transform: uppercase;
		letter-spacing: 0.02em;
	}

	.library-card__date {
		color: var(--color-lines);
	}

	.library-card__title {
		font-size: var(--text-xl);
		line-height: 1.3;
		font-weight: 500;
	}

	.library-card__title a {
		color: var(--color-not-quite-black);
		transition: color 0.2s ease;
	}

	.library-card__title a:hover {
		color: var(--color-newson-pink);
	}

	.library-card__excerpt {
		font-size: var(--text-sm);
		color: var(--color-text-grey);
		line-height: 1.6;
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.library-card__footer {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		margin-top: auto;
		padding-top: 1rem;
		border-top: 1px solid rgba(173, 172, 172, 0.08);
	}

	.library-card__tags {
		display: flex;
		gap: 0.25rem;
		overflow: hidden;
	}

	.tag-badge {
		display: inline-block;
		padding: 0.25rem 0.75rem;
		background-color: var(--color-bg-secondary);
		color: var(--color-text-grey);
		font-size: var(--text-xs);
		font-weight: 500;
		border-radius: var(--radius-full);
		border: 1px solid rgba(173, 172, 172, 0.12);
		transition: all 0.2s ease;
	}

	.tag-badge:hover {
		background-color: var(--color-newson-pink);
		color: var(--color-white);
		border-color: var(--color-newson-pink);
	}

	.library-card__link {
		font-size: var(--text-sm);
		font-weight: 600;
		color: var(--color-newson-pink);
		flex-shrink: 0;
		transition: transform 0.2s ease;
	}

	.library-card:hover .library-card__link {
		transform: translateX(2px);
	}

	/* ── Sidebar ── */
	.category-sidebar {
		position: relative;
	}

	.sidebar-widget {
		background-color: var(--color-white);
		border: 1px solid rgba(173, 172, 172, 0.15);
		border-radius: var(--radius-lg);
		padding: 1.75rem;
		box-shadow: var(--shadow-sm);
		position: sticky;
		top: 100px;
	}

	.widget-title {
		font-size: var(--text-lg);
		font-weight: 500;
		color: var(--color-not-quite-black);
		margin-bottom: 1rem;
		border-bottom: 1.5px solid rgba(233, 81, 111, 0.15);
		padding-bottom: 0.5rem;
	}

	.booking-widget {
		background: linear-gradient(135deg, var(--color-peach) 0%, var(--color-bg-soft-pink) 100%);
		border: 1px solid rgba(233, 81, 111, 0.15);
	}

	.booking-widget__text {
		font-size: var(--text-sm);
		color: var(--color-text-grey);
		margin-bottom: 1.25rem;
		line-height: 1.5;
	}

	.w-full {
		width: 100%;
	}

	.booking-widget__phone {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.5rem;
		margin-top: 1rem;
		font-size: var(--text-sm);
		font-weight: 600;
		color: var(--color-newson-pink);
		transition: color 0.2s ease;
	}

	.booking-widget__phone:hover {
		color: var(--color-newson-pink-dark);
	}

	.no-posts {
		text-align: center;
		padding-block: 4rem;
		color: var(--color-text-grey);
	}

	.mt-4 {
		margin-top: 1.5rem;
	}
</style>
