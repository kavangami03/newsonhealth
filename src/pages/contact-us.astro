---
import Base from "../layouts/Base.astro";
import { getSiteSettings } from "emdash";
import { resolveStarterSiteIdentity } from "../utils/site-identity";
import { generateBreadcrumbSchema } from "../utils/schema";
import AnimatedReveal from "../components/AnimatedReveal";

const { siteTitle } = resolveStarterSiteIdentity(await getSiteSettings());

const breadcrumbSchema = generateBreadcrumbSchema([
	{ name: "Home", url: Astro.url.origin },
	{ name: "Contact Us", url: Astro.url.href },
]);
---

<Base
	title={`Contact Us — ${siteTitle}`}
	description="Get in touch with Newson Clinic. Reach out to our friendly clinic support team via email, telephone, or our contact form."
	schema={breadcrumbSchema}
>
	<!-- ═══════════════════════════════════════
	     CONTACT HERO (RADICAL REDESIGN)
	     ═══════════════════════════════════════ -->
	<header class="relative bg-[#fcfcfc] pt-32 pb-24 md:pt-40 md:pb-32 overflow-hidden border-b border-black/5">
		<!-- Huge soft abstract blooms -->
		<div class="absolute inset-0 flex justify-center items-center pointer-events-none z-0">
			<div class="w-[800px] h-[800px] bg-gradient-to-tr from-[#fdf5f1] to-[#f7d3d9]/60 rounded-full blur-[100px] absolute top-[-30%] right-[-10%] opacity-80 mix-blend-multiply"></div>
			<div class="w-[600px] h-[600px] bg-[#ea526f]/5 rounded-full blur-[100px] absolute bottom-[-20%] left-[-10%]"></div>
		</div>

		<div class="container mx-auto px-6 max-w-[1400px] relative z-10">
			<AnimatedReveal client:visible duration={1.2} yOffset={30}>
				<nav class="flex items-center gap-3 text-[11px] font-bold tracking-widest uppercase mb-10" aria-label="Breadcrumb">
					<a href="/" class="text-[#666] hover:text-[#ea526f] transition-colors">Home</a>
					<span class="text-black/20">/</span>
					<span class="text-[#ea526f]">Contact Us</span>
				</nav>
				
				<div class="max-w-3xl">
					<h1 class="font-display text-[4rem] md:text-[5.5rem] leading-[1.05] tracking-tight text-not-quite-black mb-8 text-balance">
						Let's start the <br />
						<span class="text-[#ea526f] italic font-light relative">
							conversation.
							<svg class="absolute w-[110%] h-4 -bottom-2 -left-2 text-[#ea526f]/20" viewBox="0 0 100 10" preserveAspectRatio="none"><path d="M0 5Q50 10 100 5" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"/></svg>
						</span>
					</h1>
					<p class="text-[1.2rem] md:text-[1.35rem] text-[#666] leading-relaxed font-medium">
						Whether you have a question about booking your appointment, our fees, or how we work, our friendly patient support team is here to help.
					</p>
				</div>
			</AnimatedReveal>
		</div>
	</header>

	<!-- ═══════════════════════════════════════
	     CONTACT SECTION
	     ═══════════════════════════════════════ -->
	<main class="relative bg-[#fdf5f1] py-24 md:py-32 overflow-hidden" id="contact-details-section">
		<!-- Backdrop for form -->
		<div class="absolute top-[10%] right-[10%] w-[600px] h-[600px] bg-[#ea526f]/5 rounded-full blur-[120px] pointer-events-none z-0"></div>
		
		<div class="container mx-auto px-6 max-w-[1400px] relative z-10">
			<div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16">
				
				<!-- Left Column: Contact Form (7 columns wide) -->
				<section id="form-container" class="lg:col-span-7">
					<AnimatedReveal client:visible yOffset={40}>
						
						<form class="bg-white/80 backdrop-blur-3xl rounded-[2.5rem] p-8 md:p-12 shadow-[0_30px_80px_rgba(0,0,0,0.06)] border border-white" id="clinic-contact-form" onsubmit="event.preventDefault(); alert('Thank you for reaching out! We will get back to you within 24 hours.');">
							
							<div class="mb-10">
								<h2 class="text-[2rem] font-display text-not-quite-black tracking-tight mb-2">Send us a message</h2>
								<p class="text-[1.05rem] text-[#666] font-medium">We usually respond within 24 hours on business days.</p>
							</div>

							<div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
								<div class="flex flex-col gap-2">
									<label for="contact-name" class="text-[11px] font-bold text-[#ea526f] uppercase tracking-widest pl-4">Your Name</label>
									<input type="text" id="contact-name" name="name" required placeholder="e.g. Jane Doe" class="px-6 py-4.5 rounded-full border border-black/5 bg-[#fdf5f1]/50 text-[1rem] text-not-quite-black outline-none placeholder:text-[#aaa] transition-all duration-400 focus:border-[#ea526f]/30 focus:bg-white focus:shadow-[0_10px_30px_rgba(233,81,111,0.1)]" />
								</div>
								<div class="flex flex-col gap-2">
									<label for="contact-email" class="text-[11px] font-bold text-[#ea526f] uppercase tracking-widest pl-4">Email Address</label>
									<input type="email" id="contact-email" name="email" required placeholder="e.g. jane@example.com" class="px-6 py-4.5 rounded-full border border-black/5 bg-[#fdf5f1]/50 text-[1rem] text-not-quite-black outline-none placeholder:text-[#aaa] transition-all duration-400 focus:border-[#ea526f]/30 focus:bg-white focus:shadow-[0_10px_30px_rgba(233,81,111,0.1)]" />
								</div>
							</div>
							
							<div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
								<div class="flex flex-col gap-2">
									<label for="contact-phone" class="text-[11px] font-bold text-[#ea526f] uppercase tracking-widest pl-4">Phone Number</label>
									<input type="tel" id="contact-phone" name="phone" placeholder="e.g. 07123 456789" class="px-6 py-4.5 rounded-full border border-black/5 bg-[#fdf5f1]/50 text-[1rem] text-not-quite-black outline-none placeholder:text-[#aaa] transition-all duration-400 focus:border-[#ea526f]/30 focus:bg-white focus:shadow-[0_10px_30px_rgba(233,81,111,0.1)]" />
								</div>
								<div class="flex flex-col gap-2 relative">
									<label for="contact-subject" class="text-[11px] font-bold text-[#ea526f] uppercase tracking-widest pl-4">How can we help?</label>
									<select id="contact-subject" name="subject" required class="px-6 py-4.5 rounded-full border border-black/5 bg-[#fdf5f1]/50 text-[1rem] text-[#666] outline-none transition-all duration-400 focus:border-[#ea526f]/30 focus:bg-white focus:shadow-[0_10px_30px_rgba(233,81,111,0.1)] appearance-none cursor-pointer">
										<option value="" disabled selected>Select an option...</option>
										<option value="appointment">Booking an Appointment</option>
										<option value="prescription">Prescription / Medication Query</option>
										<option value="pricing">Fees &amp; Prices</option>
										<option value="general">General Enquiry</option>
									</select>
									<div class="absolute right-6 top-[2.2rem] pointer-events-none text-[#ea526f]">
										<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg>
									</div>
								</div>
							</div>
							
							<div class="flex flex-col gap-2 mb-10">
								<label for="contact-message" class="text-[11px] font-bold text-[#ea526f] uppercase tracking-widest pl-4">Your Message</label>
								<textarea id="contact-message" name="message" required rows="5" placeholder="Please let us know how we can support you..." class="px-6 py-5 rounded-[2rem] border border-black/5 bg-[#fdf5f1]/50 text-[1rem] text-not-quite-black outline-none placeholder:text-[#aaa] transition-all duration-400 focus:border-[#ea526f]/30 focus:bg-white focus:shadow-[0_10px_30px_rgba(233,81,111,0.1)] resize-none min-h-[160px]"></textarea>
							</div>
							
							<div>
								<button type="submit" class="px-10 py-4.5 w-full bg-[#ea526f] text-white text-[13px] font-bold uppercase tracking-widest rounded-full shadow-[0_15px_30px_rgba(233,81,111,0.25)] hover:shadow-[0_20px_40px_rgba(233,81,111,0.4)] hover:-translate-y-1 transition-all duration-400 flex justify-center items-center gap-3 group" id="contact-submit-btn">
									Send Message
									<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-1 group-hover:-translate-y-1 transition-transform"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
								</button>
							</div>
						</form>
					</AnimatedReveal>
				</section>

				<!-- Right Column: Clinic Info Widgets (5 columns wide) -->
				<aside aria-label="Clinic Details" class="lg:col-span-5 flex flex-col gap-6">
					
					<!-- Widget 1: Location -->
					<AnimatedReveal client:visible yOffset={40} delay={0.1}>
						<div class="bg-white rounded-[2rem] p-8 shadow-[0_10px_30px_rgba(0,0,0,0.03)] border border-black/5 hover:-translate-y-1 transition-transform duration-500 flex gap-6 items-start group">
							<div class="w-16 h-16 rounded-full bg-[#fdf5f1] flex items-center justify-center shrink-0 border border-[#ea526f]/10 shadow-sm text-[#ea526f] group-hover:scale-110 transition-transform duration-500">
								<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
							</div>
							<div>
								<h3 class="text-[12px] font-bold text-[#ea526f] uppercase tracking-widest mb-2">Our Location</h3>
								<p class="text-[1.1rem] text-not-quite-black font-medium leading-relaxed mb-4">
									Winton House, Church Street,<br />
									Stratford-upon-Avon, Warwickshire,<br />
									CV37 6HB
								</p>
								<a href="#" class="text-[13px] font-bold uppercase tracking-widest text-not-quite-black underline decoration-2 decoration-[#ea526f]/30 hover:decoration-[#ea526f] transition-colors underline-offset-4">Get Directions</a>
							</div>
						</div>
					</AnimatedReveal>

					<!-- Widget 2: Patient Helpline -->
					<AnimatedReveal client:visible yOffset={40} delay={0.2}>
						<div class="bg-white rounded-[2rem] p-8 shadow-[0_10px_30px_rgba(0,0,0,0.03)] border border-black/5 hover:-translate-y-1 transition-transform duration-500 flex gap-6 items-start group">
							<div class="w-16 h-16 rounded-full bg-[#fdf5f1] flex items-center justify-center shrink-0 border border-[#ea526f]/10 shadow-sm text-[#ea526f] group-hover:scale-110 transition-transform duration-500">
								<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
							</div>
							<div>
								<h3 class="text-[12px] font-bold text-[#ea526f] uppercase tracking-widest mb-2">Patient Helpline</h3>
								<p class="text-[1.5rem] font-display text-not-quite-black leading-tight mb-2">
									<a href="tel:01789595004" class="hover:text-[#ea526f] transition-colors">01789 595004</a>
								</p>
								<p class="text-[13px] text-[#666] font-medium tracking-wide">
									Monday – Friday, 9:00am to 5:00pm
								</p>
							</div>
						</div>
					</AnimatedReveal>

					<!-- Widget 3: Support Email -->
					<AnimatedReveal client:visible yOffset={40} delay={0.3}>
						<div class="bg-[#ea526f] rounded-[2rem] p-8 shadow-[0_20px_40px_rgba(233,81,111,0.2)] hover:-translate-y-1 transition-transform duration-500 flex gap-6 items-start group relative overflow-hidden">
							<!-- Decor -->
							<div class="absolute -right-10 -bottom-10 w-40 h-40 bg-white/10 rounded-full blur-2xl"></div>
							
							<div class="w-16 h-16 rounded-full bg-white/10 flex items-center justify-center shrink-0 border border-white/20 shadow-sm text-white group-hover:scale-110 transition-transform duration-500">
								<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
							</div>
							<div class="relative z-10">
								<h3 class="text-[12px] font-bold text-white/90 uppercase tracking-widest mb-2">Support Email</h3>
								<p class="text-[1.1rem] text-white font-medium leading-relaxed">
									<a href="mailto:info@newsonhealth.co.uk" class="hover:underline underline-offset-4 decoration-white/50">info@newsonhealth.co.uk</a>
								</p>
							</div>
						</div>
					</AnimatedReveal>

					<!-- Widget 4: Accessibility -->
					<AnimatedReveal client:visible yOffset={40} delay={0.4}>
						<div class="bg-white rounded-[2rem] p-8 shadow-[0_10px_30px_rgba(0,0,0,0.03)] border border-black/5 hover:-translate-y-1 transition-transform duration-500">
							<h3 class="text-[12px] font-bold text-[#ea526f] uppercase tracking-widest mb-3">Parking &amp; Accessibility</h3>
							<p class="text-[1rem] text-[#666] leading-relaxed font-medium">
								Winton House has dedicated patient parking spaces located to the rear of the building. Level access is available via our main reception, and all patient consultation rooms are fully wheelchair accessible.
							</p>
						</div>
					</AnimatedReveal>

				</aside>
				
			</div>
		</div>
	</main>
</Base>
