---
import { getMenu, getSiteSettings } from "emdash";
import { resolveStarterSiteIdentity } from "../utils/site-identity";
import LiveSearch from "emdash/ui/search";
import MegaMenu from "./MegaMenu";
import AppointmentDropdown from "./AppointmentDropdown";
import customLogo from "../images/logo.svg";
import Logo from "./Logo.astro";

const { siteTitle } = resolveStarterSiteIdentity(await getSiteSettings());
---

<header class="fixed top-4 md:top-6 left-1/2 -translate-x-1/2 w-[95%] max-w-[1400px] z-[150] transition-all duration-500 ease-out-expo" id="global-header">
	<div class="relative bg-white/85 backdrop-blur-3xl border border-white/60 shadow-[0_20px_60px_rgba(0,0,0,0.06)] rounded-full px-4 md:px-8 transition-all duration-500" id="header-bg">
		<div class="flex items-center justify-between h-16 md:h-[5.5rem] transition-all duration-500 ease-out-expo" id="header-inner">
			
			<!-- Logo -->
			<a href="/" class="flex-shrink-0 relative z-[120] group pl-2" aria-label="Go to homepage">
				<Logo class="w-auto h-7 md:h-9 transition-transform duration-500 ease-out-expo group-hover:scale-105" id="header-logo" />
			</a>

			<!-- Right Actions -->
			<div class="flex items-center gap-4 md:gap-8 relative z-20">
				
				<!-- Search -->
				<div class="hidden lg:block relative group premium-search-container">
					<div class="absolute left-4 top-1/2 -translate-y-1/2 text-[#ea526f] pointer-events-none z-10 transition-colors duration-300">
						<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
					</div>
					
					<LiveSearch 
						placeholder="Search the clinic..." 
						collections={["posts", "pages"]} 
						class="block"
						inputClass="!w-full bg-[#fdf5f1]/60 hover:bg-[#fdf5f1] focus:bg-white backdrop-blur-md border border-transparent focus:border-[#ea526f]/30 rounded-full py-3 pl-12 pr-5 text-[13px] font-bold tracking-wide text-not-quite-black transition-all duration-500 ease-out-expo shadow-inner focus:shadow-[0_0_20px_rgba(233,81,111,0.15)] outline-none placeholder:text-[#888] placeholder:font-semibold"
						expandOnFocus={{ collapsed: "280px", expanded: "350px" }}
						resultsClass="!bg-white/95 backdrop-blur-3xl !border-black/5 !rounded-3xl !shadow-[0_20px_50px_rgba(0,0,0,0.1)] mt-4 overflow-hidden !max-h-[400px]"
						resultClass="hover:bg-[#fdf5f1] focus:bg-[#fdf5f1] transition-colors"
					/>
				</div>

				<!-- Appointment Dropdown (React Island) -->
				<div class="hidden md:block border-l border-black/5 pl-8">
					<AppointmentDropdown client:load />
				</div>

				<!-- Mobile Appointment Button (Fallback) -->
				<a href="https://portal.newsonhealth.co.uk/patient-portal/booking-request" target="_blank" class="md:hidden px-5 py-2.5 bg-[#ea526f] text-white text-[11px] font-bold uppercase tracking-widest rounded-full">
					Book
				</a>

				<!-- Mega Menu Toggle (React Island) -->
				<MegaMenu client:load logoSrc={customLogo?.src} />
				
			</div>
		</div>
	</div>
</header>

<script>
	import { gsap } from "gsap";
	import { ScrollTrigger } from "gsap/ScrollTrigger";

	gsap.registerPlugin(ScrollTrigger);

	document.addEventListener("DOMContentLoaded", () => {
		const header = document.getElementById("global-header");
		const headerBg = document.getElementById("header-bg");
		const headerInner = document.getElementById("header-inner");
		const logo = document.getElementById("header-logo");

		if (!header || !headerBg || !headerInner || !logo) return;

		let lastScrollY = window.scrollY;

		// Initialize GSAP transform to match Tailwind centering
		gsap.set(header, { xPercent: -50 });

		// Handle subtle shrink and background on scroll
		ScrollTrigger.create({
			start: "top -50",
			end: 99999,
			toggleClass: { className: 'is-scrolled', targets: header },
			onUpdate: (self) => {
				const currentScrollY = window.scrollY;
				
				// Add background blur when scrolled down slightly
				if (currentScrollY > 20) {
					headerBg.classList.add('shadow-[0_20px_40px_rgba(0,0,0,0.08)]', 'border-[#ea526f]/10');
					headerInner.classList.remove('h-16', 'md:h-[5.5rem]');
					headerInner.classList.add('h-14', 'md:h-16');
					logo.classList.remove('h-7', 'md:h-9');
					logo.classList.add('h-6', 'md:h-7');
				} else {
					headerBg.classList.remove('shadow-[0_20px_40px_rgba(0,0,0,0.08)]', 'border-[#ea526f]/10');
					headerInner.classList.remove('h-14', 'md:h-16');
					headerInner.classList.add('h-16', 'md:h-[5.5rem]');
					logo.classList.remove('h-6', 'md:h-7');
					logo.classList.add('h-7', 'md:h-9');
				}

				// Hide/Reveal Header on scroll direction
				if (currentScrollY > 150) {
					if (currentScrollY > lastScrollY && self.direction === 1) {
						// Scrolling down - hide header
						gsap.to(header, { yPercent: -150, xPercent: -50, duration: 0.5, ease: "power3.inOut" });
					} else if (currentScrollY < lastScrollY && self.direction === -1) {
						// Scrolling up - show header
						gsap.to(header, { yPercent: 0, xPercent: -50, duration: 0.5, ease: "power3.out" });
					}
				} else {
					// Always show at top
					gsap.to(header, { yPercent: 0, xPercent: -50, duration: 0.5, ease: "power3.out" });
				}

				lastScrollY = currentScrollY;
			}
		});
	});
</script>
