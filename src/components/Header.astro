---
import { getSiteSettings } from "emdash";
import { resolveStarterSiteIdentity } from "../utils/site-identity";
import MegaMenu from "./MegaMenu";
import AppointmentDropdown from "./AppointmentDropdown";
import customLogo from "../images/logo.svg";
import Logo from "./Logo.astro";

const { siteTitle } = resolveStarterSiteIdentity(await getSiteSettings());
---

<div class="fixed top-0 left-0 right-0 z-[150] transition-all duration-500 ease-out-expo pointer-events-none" id="global-header-wrap">
	<!-- ═══ TOP TRUST RIBBON ═══ -->
	<div
		class="pointer-events-auto bg-gradient-to-r from-[#ea526f] via-[#e63d5d] to-[#ea526f] text-white transition-all duration-500 ease-out-expo overflow-hidden"
		id="trust-ribbon"
	>
		<div class="max-w-[1640px] mx-auto px-4 md:px-6 lg:px-10 h-9 md:h-10 flex items-center justify-between gap-4 text-[11px] md:text-[12px] font-medium">
			<!-- Left: rotating trust messages -->
			<div class="flex-1 overflow-hidden relative h-5">
				<div class="absolute inset-0 flex flex-col transition-transform duration-700 ease-out-expo" id="ribbon-messages">
					<span class="h-5 flex items-center gap-2 whitespace-nowrap">
						<svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
						<span><strong class="font-bold">Outstanding</strong> rated by the Care Quality Commission</span>
					</span>
					<span class="h-5 flex items-center gap-2 whitespace-nowrap">
						<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
						<span>Speak with our patient team — <strong class="font-bold">01789 595004</strong></span>
					</span>
					<span class="h-5 flex items-center gap-2 whitespace-nowrap">
						<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
						<span>Monday – Friday · 9:00am – 5:00pm</span>
					</span>
					<span class="h-5 flex items-center gap-2 whitespace-nowrap">
						<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
						<span>Pay over time with <strong class="font-bold">Klarna</strong></span>
					</span>
				</div>
			</div>

			<!-- Right: fixed quick links -->
			<div class="hidden md:flex items-center gap-5">
				<a href="tel:01789595004" class="inline-flex items-center gap-1.5 hover:text-white/80 transition-colors group">
					<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
					<span class="font-bold tracking-wide">01789 595004</span>
				</a>
				<span class="w-px h-3.5 bg-white/30" aria-hidden="true"></span>
				<a href="https://portal.newsonhealth.co.uk/patient-portal" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 hover:text-white/80 transition-colors">
					<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
					<span class="font-bold tracking-wide">Patient Portal</span>
				</a>
			</div>
		</div>
	</div>

	<!-- ═══ MAIN HEADER PILL ═══ -->
	<div class="px-4 md:px-6 lg:px-10 max-w-[1640px] mx-auto mt-3 md:mt-4" id="header-frame">
		<header
			class="pointer-events-auto relative bg-white/95 backdrop-blur-3xl border border-white/70 rounded-full shadow-[0_25px_60px_-15px_rgba(0,0,0,0.1),0_0_0_1px_rgba(255,255,255,0.4)] transition-all duration-500 ease-out-expo"
			id="global-header"
		>
			<!-- Subtle pink gradient line at top -->
			<div class="absolute top-0 left-1/2 -translate-x-1/2 w-[40%] h-[1px] bg-gradient-to-r from-transparent via-[#ea526f]/50 to-transparent pointer-events-none" aria-hidden="true"></div>

			<div class="flex items-center justify-between gap-3 md:gap-6 lg:gap-8 h-[68px] md:h-20 px-4 md:px-6 lg:px-8 transition-all duration-500 ease-out-expo" id="header-inner">
				<!-- LOGO -->
				<a href="/" class="flex-shrink-0 relative z-[120] group" aria-label={`${siteTitle} home`}>
					<Logo
						class="w-auto h-9 md:h-11 lg:h-12 transition-transform duration-500 ease-out-expo group-hover:scale-[1.04]"
						id="header-logo"
					/>
				</a>

				<!-- INLINE NAV (desktop) -->
				<nav class="hidden lg:flex items-center gap-1" aria-label="Primary">
					<button type="button" data-megamenu-trigger class="header-nav-link group relative px-4 py-2.5 inline-flex items-center gap-1.5 text-[13px] font-bold uppercase tracking-[0.12em] text-not-quite-black hover:text-[#ea526f] transition-colors duration-300">
						<span>Services</span>
						<svg class="w-2.5 h-2.5 transition-transform duration-300 group-hover:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
					</button>
					<button type="button" data-megamenu-trigger class="header-nav-link group relative px-4 py-2.5 inline-flex items-center gap-1.5 text-[13px] font-bold uppercase tracking-[0.12em] text-not-quite-black hover:text-[#ea526f] transition-colors duration-300">
						<span>Knowledge</span>
						<svg class="w-2.5 h-2.5 transition-transform duration-300 group-hover:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
					</button>
					<a href="/clinics" class="header-nav-link px-4 py-2.5 text-[13px] font-bold uppercase tracking-[0.12em] text-not-quite-black hover:text-[#ea526f] transition-colors duration-300">
						Clinics
					</a>
					<a href="/about-us" class="header-nav-link px-4 py-2.5 text-[13px] font-bold uppercase tracking-[0.12em] text-not-quite-black hover:text-[#ea526f] transition-colors duration-300">
						About
					</a>
				</nav>

				<!-- RIGHT CLUSTER -->
				<div class="flex items-center gap-2 md:gap-2.5 flex-shrink-0">
					<!-- Search icon -->
					<button type="button" id="header-search-toggle" class="hidden md:flex w-11 h-11 rounded-full bg-[#fdf5f1] hover:bg-[#ea526f] text-[#ea526f] hover:text-white items-center justify-center transition-colors duration-300" aria-label="Open search">
						<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
					</button>

					<!-- Book dropdown (desktop) -->
					<div class="hidden md:block">
						<AppointmentDropdown client:load />
					</div>

					<!-- Mobile -->
					<button type="button" id="mobile-search-toggle" class="md:hidden w-11 h-11 rounded-full bg-[#fdf5f1] text-[#ea526f] flex items-center justify-center" aria-label="Open search">
						<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
					</button>
					<a href="https://portal.newsonhealth.co.uk/patient-portal/booking-request" target="_blank" rel="noopener noreferrer" class="md:hidden inline-flex items-center px-4 h-11 bg-[#ea526f] text-white text-[11px] font-bold uppercase tracking-widest rounded-full shadow-[0_10px_25px_rgba(233,81,111,0.4)]">
						Book
					</a>

					<MegaMenu client:load logoSrc={customLogo?.src} />
				</div>
			</div>
		</header>
	</div>
</div>

<script>
	import { gsap } from "gsap";
	import { ScrollTrigger } from "gsap/ScrollTrigger";

	gsap.registerPlugin(ScrollTrigger);

	document.addEventListener("DOMContentLoaded", () => {
		const wrap = document.getElementById("global-header-wrap");
		const header = document.getElementById("global-header");
		const inner = document.getElementById("header-inner");
		const logo = document.getElementById("header-logo");
		const ribbon = document.getElementById("trust-ribbon");
		const ribbonMessages = document.getElementById("ribbon-messages");

		if (!wrap || !header || !inner || !logo) return;

		let lastScrollY = window.scrollY;

		// Ribbon message rotator
		if (ribbonMessages) {
			let i = 0;
			const count = ribbonMessages.children.length;
			setInterval(() => {
				i = (i + 1) % count;
				ribbonMessages.style.transform = `translateY(-${i * 20}px)`;
			}, 4000);
		}

		ScrollTrigger.create({
			start: "top -50",
			end: 99999,
			toggleClass: { className: "is-scrolled", targets: wrap },
			onUpdate: (self) => {
				const y = window.scrollY;

				if (y > 20) {
					// Collapse: shrink header, hide ribbon
					inner.classList.remove("h-[68px]", "md:h-20");
					inner.classList.add("h-[60px]", "md:h-[68px]");
					logo.classList.remove("h-9", "md:h-11", "lg:h-12");
					logo.classList.add("h-7", "md:h-9", "lg:h-10");
					header.classList.add("shadow-[0_20px_50px_-15px_rgba(233,81,111,0.25)]");
					ribbon?.classList.add("h-0", "max-h-0", "opacity-0");
					ribbon?.classList.remove("h-9", "md:h-10", "opacity-100");
				} else {
					inner.classList.add("h-[68px]", "md:h-20");
					inner.classList.remove("h-[60px]", "md:h-[68px]");
					logo.classList.add("h-9", "md:h-11", "lg:h-12");
					logo.classList.remove("h-7", "md:h-9", "lg:h-10");
					header.classList.remove("shadow-[0_20px_50px_-15px_rgba(233,81,111,0.25)]");
					ribbon?.classList.remove("h-0", "max-h-0", "opacity-0");
					ribbon?.classList.add("h-9", "md:h-10", "opacity-100");
				}

				if (y > 200) {
					if (y > lastScrollY && self.direction === 1) {
						gsap.to(wrap, { yPercent: -120, duration: 0.5, ease: "power3.inOut" });
					} else if (y < lastScrollY && self.direction === -1) {
						gsap.to(wrap, { yPercent: 0, duration: 0.5, ease: "power3.out" });
					}
				} else {
					gsap.to(wrap, { yPercent: 0, duration: 0.5, ease: "power3.out" });
				}

				lastScrollY = y;
			},
		});

		// Inline nav (Services / Knowledge) — clicking opens the mega menu
		document.querySelectorAll<HTMLButtonElement>("[data-megamenu-trigger]").forEach((btn) => {
			btn.addEventListener("click", () => {
				const menuTrigger = document.querySelector<HTMLButtonElement>('button[aria-label="Open menu"]');
				menuTrigger?.click();
			});
		});

		// Search overlay (shared by desktop + mobile triggers)
		const openSearchOverlay = () => {
			if (document.getElementById("global-search-overlay")) return;
			const overlay = document.createElement("div");
			overlay.id = "global-search-overlay";
			overlay.className =
				"fixed inset-0 z-[160] bg-[#1a0a10]/50 backdrop-blur-md flex items-start justify-center pt-28 px-6 transition-opacity duration-300 opacity-0";
			overlay.innerHTML = `
				<div class="w-full max-w-2xl relative">
					<div class="bg-white rounded-3xl shadow-[0_30px_80px_-20px_rgba(233,81,111,0.4)] p-3">
						<div class="relative">
							<span class="absolute left-5 top-1/2 -translate-y-1/2 text-[#ea526f] pointer-events-none">
								<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
							</span>
							<input id="global-search-input" type="search" placeholder="Search the clinic…" class="w-full bg-[#fdf5f1] focus:bg-white border border-transparent focus:border-[#ea526f]/30 rounded-2xl py-4 pl-14 pr-14 text-[16px] font-medium text-not-quite-black outline-none transition-colors" />
							<button type="button" class="absolute right-3 top-1/2 -translate-y-1/2 w-9 h-9 rounded-full bg-black/5 hover:bg-[#ea526f] hover:text-white text-not-quite-black flex items-center justify-center transition-colors" aria-label="Close search">
								<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
							</button>
						</div>
						<p class="px-5 py-3 text-[11px] tracking-wider uppercase text-[#888] font-bold">Press <kbd class="px-1.5 py-0.5 rounded bg-black/5 font-mono text-[10px] text-[#444]">Esc</kbd> to close</p>
					</div>
				</div>
			`;
			document.body.appendChild(overlay);
			document.body.style.overflow = "hidden";
			requestAnimationFrame(() => (overlay.style.opacity = "1"));
			(overlay.querySelector("#global-search-input") as HTMLInputElement | null)?.focus();
			const close = () => {
				overlay.style.opacity = "0";
				setTimeout(() => {
					overlay.remove();
					document.body.style.overflow = "";
				}, 200);
			};
			overlay.addEventListener("click", (e) => {
				if (e.target === overlay) close();
			});
			overlay.querySelector("button[aria-label='Close search']")?.addEventListener("click", close);
			document.addEventListener("keydown", function esc(e) {
				if (e.key === "Escape") {
					close();
					document.removeEventListener("keydown", esc);
				}
			});
		};
		document.getElementById("header-search-toggle")?.addEventListener("click", openSearchOverlay);
		document.getElementById("mobile-search-toggle")?.addEventListener("click", openSearchOverlay);
	});
</script>

<style>
	/* Nav link underline animation */
	.header-nav-link {
		position: relative;
	}
	.header-nav-link::after {
		content: "";
		position: absolute;
		left: 16px;
		right: 16px;
		bottom: 6px;
		height: 1.5px;
		background: #ea526f;
		transform: scaleX(0);
		transform-origin: left;
		transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
	}
	.header-nav-link:hover::after {
		transform: scaleX(1);
	}
</style>
