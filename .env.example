# Local dev only — encrypts emdash fields. Generate one for production too.
EMDASH_ENCRYPTION_KEY=emdash_enc_v1_replace_with_your_value

# ─────────────────────────────────────────────
# Production (Vercel) only — set in Vercel dashboard, not committed
# ─────────────────────────────────────────────

# Turso (libSQL cloud) — replaces local SQLite in production
TURSO_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=eyJhbGciOi...

# Cloudflare R2 (or any S3-compatible bucket) — replaces local ./uploads in production
S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
S3_BUCKET=newsonhealth-media
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=auto
# Public read URL where uploaded files are served. For R2 with a custom domain:
#   https://media.yourdomain.com
# For R2 with the default r2.dev URL:
#   https://pub-<hash>.r2.dev
S3_PUBLIC_URL=https://pub-xxxxxxxxxxxxxxxxxxxx.r2.dev
