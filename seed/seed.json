{
	"$schema": "https://emdashcms.com/seed.schema.json",
	"version": "1",
	"meta": {
		"name": "Newson Health Modular CMS",
		"description": "Modular CMS for Newson Clinic. Each homepage section is one entry in home_sections; reusable lists (services, clinics, appointments, clinicians, posts, faqs) are their own collections.",
		"author": "Antigravity"
	},
	"settings": {
		"title": "Newson Health",
		"tagline": "Evidence-based Menopause & Hormone Care"
	},
	"collections": [
		{
			"slug": "home_sections",
			"label": "Homepage",
			"labelSingular": "Section",
			"icon": "house",
			"description": "Editable text + media for each section of the homepage. One entry per section (hero, founders, services, clinics, appointments, advice, clinicians).",
			"supports": ["drafts", "search"],
			"fields": [
				{ "slug": "title", "label": "Title", "type": "string", "required": true, "searchable": true },
				{ "slug": "subtitle", "label": "Eyebrow / Subtitle", "type": "string" },
				{ "slug": "description", "label": "Description", "type": "text", "searchable": true },
				{ "slug": "content", "label": "Long-form Content", "type": "text" },
				{ "slug": "button_text", "label": "Button Text", "type": "string" },
				{ "slug": "button_url", "label": "Button URL", "type": "string" },
				{ "slug": "image", "label": "Primary Image", "type": "string" },
				{ "slug": "secondary_image", "label": "Secondary Image", "type": "string" },
				{ "slug": "video_url", "label": "Video URL", "type": "string" }
			]
		},
		{
			"slug": "services",
			"label": "Services",
			"labelSingular": "Service",
			"icon": "briefcase-medical",
			"description": "Service cards shown on the homepage carousel and /services.",
			"supports": ["drafts", "search"],
			"fields": [
				{ "slug": "title", "label": "Title", "type": "string", "required": true, "searchable": true },
				{ "slug": "price", "label": "Price", "type": "string" },
				{ "slug": "text", "label": "Description", "type": "text", "searchable": true },
				{ "slug": "link", "label": "Link URL", "type": "string" },
				{ "slug": "image", "label": "Image URL", "type": "string" },
				{ "slug": "sort_order", "label": "Sort Order", "type": "integer" }
			]
		},
		{
			"slug": "clinics",
			"label": "Clinics",
			"labelSingular": "Clinic",
			"icon": "map-pin",
			"description": "Clinic locations shown on the homepage and /clinics.",
			"supports": ["drafts", "search"],
			"fields": [
				{ "slug": "title", "label": "Clinic Name", "type": "string", "required": true, "searchable": true },
				{ "slug": "address1", "label": "Address Line 1", "type": "string" },
				{ "slug": "address2", "label": "Address Line 2", "type": "string" },
				{ "slug": "town", "label": "Town / City", "type": "string" },
				{ "slug": "postcode", "label": "Postcode", "type": "string" },
				{ "slug": "image", "label": "Image URL", "type": "string" },
				{ "slug": "link", "label": "Clinic Page Link", "type": "string" },
				{ "slug": "sort_order", "label": "Sort Order", "type": "integer" }
			]
		},
		{
			"slug": "appointments",
			"label": "Appointments",
			"labelSingular": "Appointment Option",
			"icon": "calendar",
			"description": "Booking options on the homepage (Video, In-person, etc.).",
			"supports": ["drafts", "search"],
			"fields": [
				{ "slug": "title", "label": "Title", "type": "string", "required": true, "searchable": true },
				{ "slug": "subtitle", "label": "Subtitle", "type": "string" },
				{ "slug": "url", "label": "Booking URL", "type": "string" },
				{ "slug": "icon", "label": "Icon (video|map-pin)", "type": "string" },
				{ "slug": "sort_order", "label": "Sort Order", "type": "integer" }
			]
		},
		{
			"slug": "clinicians",
			"label": "Clinicians",
			"labelSingular": "Clinician",
			"icon": "stethoscope",
			"description": "Doctor and specialist profiles shown on the homepage and /meet-the-team.",
			"supports": ["drafts", "search"],
			"fields": [
				{ "slug": "name", "label": "Name", "type": "string", "required": true, "searchable": true },
				{ "slug": "role", "label": "Role", "type": "string", "required": true },
				{ "slug": "credentials", "label": "Credentials", "type": "string" },
				{ "slug": "image", "label": "Photo URL", "type": "string" },
				{ "slug": "bio", "label": "Biography", "type": "text", "searchable": true },
				{ "slug": "initials", "label": "Initials", "type": "string" },
				{ "slug": "featured", "label": "Featured (Founder)", "type": "boolean" }
			]
		},
		{
			"slug": "posts",
			"label": "Posts",
			"labelSingular": "Post",
			"icon": "newspaper",
			"description": "Blog and advice articles.",
			"supports": ["drafts", "revisions", "search", "seo"],
			"fields": [
				{ "slug": "title", "label": "Title", "type": "string", "required": true, "searchable": true },
				{ "slug": "featured_image", "label": "Featured Image", "type": "string" },
				{ "slug": "excerpt", "label": "Excerpt", "type": "text" },
				{ "slug": "content", "label": "Content", "type": "portableText", "searchable": true }
			]
		},
		{
			"slug": "faqs",
			"label": "FAQs",
			"labelSingular": "FAQ",
			"icon": "question",
			"description": "Frequently asked questions shown on /faqs.",
			"supports": ["drafts", "search"],
			"fields": [
				{ "slug": "question", "label": "Question", "type": "string", "required": true, "searchable": true },
				{ "slug": "answer", "label": "Answer", "type": "text", "required": true, "searchable": true },
				{ "slug": "category", "label": "Category", "type": "string", "required": true }
			]
		},
		{
			"slug": "pages",
			"label": "Pages",
			"labelSingular": "Page",
			"icon": "file-text",
			"description": "Generic CMS pages rendered at /[slug].",
			"supports": ["drafts", "revisions", "search"],
			"fields": [
				{ "slug": "title", "label": "Title", "type": "string", "required": true, "searchable": true },
				{ "slug": "content", "label": "Content", "type": "portableText", "searchable": true }
			]
		}
	],
	"taxonomies": [
		{
			"name": "category",
			"label": "Categories",
			"labelSingular": "Category",
			"hierarchical": true,
			"collections": ["posts"],
			"terms": [
				{ "slug": "general", "label": "General" },
				{ "slug": "updates", "label": "Updates" }
			]
		},
		{
			"name": "tag",
			"label": "Tags",
			"labelSingular": "Tag",
			"hierarchical": false,
			"collections": ["posts"],
			"terms": [
				{ "slug": "starter", "label": "Starter" },
				{ "slug": "example", "label": "Example" }
			]
		}
	],
	"content": {
		"home_sections": [
			{
				"slug": "hero",
				"status": "published",
				"data": {
					"title": "Embrace life again",
					"subtitle": "Expert Hormone Care",
					"description": "Rated Outstanding by CQC. We provide unbiased, evidence-based information to support women's hormonal health and overall wellbeing.",
					"button_text": "Start your journey",
					"button_url": "https://portal.newsonhealth.co.uk/patient-portal/booking-request",
					"video_url": ""
				}
			},
			{
				"slug": "founders",
				"status": "published",
				"data": {
					"title": "Founded by Dr Louise Newson & Dr Rebecca Lewis",
					"subtitle": "The Visionaries",
					"description": "Newson Clinic was founded by two GPs with a shared mission: to transform menopause care through evidence-based medicine and compassionate listening.",
					"button_text": "Read our story",
					"button_url": "/about"
				}
			},
			{
				"slug": "services",
				"status": "published",
				"data": {
					"title": "Ways we can help you",
					"subtitle": "Our Services",
					"description": "From initial consultations to follow-up care and specialist hormone tests, we offer a full range of services to support your health journey."
				}
			},
			{
				"slug": "clinics",
				"status": "published",
				"data": {
					"title": "Our clinics",
					"subtitle": "Locations",
					"description": "Visit us at one of our specialist clinics across the UK, or book a video consultation from anywhere in the world."
				}
			},
			{
				"slug": "appointments",
				"status": "published",
				"data": {
					"title": "Appointments that work round you.",
					"subtitle": "Your Journey",
					"description": "Choose the appointment type that suits you best — in person at one of our clinics, or remotely via video consultation."
				}
			},
			{
				"slug": "advice",
				"status": "published",
				"data": {
					"title": "Advice and information",
					"subtitle": "Knowledge Hub",
					"description": "Browse our latest articles on hormones, menopause, HRT, and women's health, written by our specialist clinicians."
				}
			},
			{
				"slug": "clinicians",
				"status": "published",
				"data": {
					"title": "Meet our clinicians",
					"subtitle": "Our Team",
					"description": "Our team of GP menopause specialists are here to listen, support, and provide expert care tailored to you."
				}
			}
		]
	}
}
