    "faqs": [
      {
        "id": "faq-1",
        "slug": "faq-1",
        "status": "published",
        "data": {
          "question": "How do I book a consultation at Newson Clinic?",
          "answer": "You can book an appointment by filling out our online booking request form on our secure Patient Portal, or by calling our patient support team on 01789 595004. We offer both in-person consultations at our clinics and video consultations nationwide.",
          "category": "Consultations & Appointments"
        }
      },
      {
        "id": "faq-2",
        "slug": "faq-2",
        "status": "published",
        "data": {
          "question": "Do you offer online video consultations?",
          "answer": "Yes, we offer secure video consultations for patients across the UK and internationally. Video consultations are highly popular, highly convenient, and held with the exact same expert GP Menopause Specialists as our in-person visits.",
          "category": "Consultations & Appointments"
        }
      },
      {
        "id": "faq-3",
        "slug": "faq-3",
        "status": "published",
        "data": {
          "question": "Do I need a GP referral to visit Newson Clinic?",
          "answer": "No, you do not need a GP referral. We welcome self-referrals from all patients seeking specialized menopause support, perimenopause support, or hormone wellness advice.",
          "category": "Consultations & Appointments"
        }
      },
      {
        "id": "faq-4",
        "slug": "faq-4",
        "status": "published",
        "data": {
          "question": "What type of HRT do you prescribe?",
          "answer": "We prioritize prescribing body-identical (also known as regulated bio-identical) hormones, which are derived from natural plant sources (yam) and are structurally identical to the hormones produced by your own body. These carry significantly lower risks compared to older synthetic hormones.",
          "category": "Hormone Replacement Therapy (HRT)"
        }
      },
      {
        "id": "faq-5",
        "slug": "faq-5",
        "status": "published",
        "data": {
          "question": "How long does it take for HRT to start working?",
          "answer": "Many patients start noticing improvements in symptoms like hot flushes and night sweats within 2 to 4 weeks. However, other symptoms such as joint pain, mood shifts, and brain fog can take 3 to 6 months to fully stabilize. We schedule follow-ups at 3 months to monitor progress.",
          "category": "Hormone Replacement Therapy (HRT)"
        }
      },
      {
        "id": "faq-6",
        "slug": "faq-6",
        "status": "published",
        "data": {
          "question": "Are body-identical hormones safe?",
          "answer": "Yes, body-identical hormones (specifically transdermal oestrogen and micronised progesterone) have an outstanding safety profile. Unlike older synthetic oral treatments, transdermal oestrogen does not increase the risk of blood clots or stroke, and carries no increased risk of breast cancer when used appropriately.",
          "category": "Hormone Replacement Therapy (HRT)"
        }
      },
      {
        "id": "faq-7",
        "slug": "faq-7",
        "status": "published",
        "data": {
          "question": "Do I need blood tests before my first consultation?",
          "answer": "Not necessarily. In most cases, perimenopause and menopause are diagnosed based on your symptoms and clinical history rather than blood hormone levels (which can fluctuate wildly from day to day). Your clinician will advise you during your initial consultation if blood tests are necessary.",
          "category": "Blood Tests & Diagnostics"
        }
      },
      {
        "id": "faq-8",
        "slug": "faq-8",
        "status": "published",
        "data": {
          "question": "What is a DEXA scan and why is it important?",
          "answer": "A DEXA scan is a quick, painless scan that measures bone mineral density. Since oestrogen declines during menopause, bone loss can accelerate, increasing the risk of osteoporosis. We offer DEXA scans at our Stratford clinic to assess bone health and screen for osteoporosis risk.",
          "category": "Blood Tests & Diagnostics"
        }
      }
    ],
